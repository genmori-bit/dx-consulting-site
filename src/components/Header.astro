---
import { SITE } from "../config";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const nav = [
  { href: `${base}services/`, label: "支援内容" },
  { href: `${base}local-business/`, label: "地域企業のDX" },
  { href: `${base}#process`, label: "支援の流れ" },
  { href: `${base}company/`, label: "ミチカクについて" },
];
---

<header class="header" id="site-header">
  <div class="header__inner">
    <!-- D案メインロゴ:ワードマーク+道筋の線 -->
    <a href={base} class="header__brand" aria-label={`${SITE.brandJa} — ${SITE.tagline}`}>
      <span class="header__brand-name">ミチカク</span>
      <svg
        class="header__brand-line"
        viewBox="0 0 132 12"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M2 7 C 24 3, 44 10, 66 7 C 88 4, 106 8, 118 6"
          stroke="#2E6E5A"
          stroke-width="2.4"
          stroke-linecap="round"></path>
        <circle cx="126" cy="5.5" r="4" fill="#E06A3F"></circle>
      </svg>
    </a>
    <nav class="header__nav" aria-label="メインナビゲーション">
      {nav.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    <a href={`${base}#contact`} class="header__cta">相談する</a>
  </div>
</header>

<script>
  const header = document.getElementById("site-header");
  const onScroll = () => {
    header?.classList.toggle("is-scrolled", window.scrollY > 32);
  };
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });
</script>

<style>
  .header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    transition: background-color 0.5s ease, border-color 0.5s ease;
    border-bottom: 1px solid transparent;
  }

  .header.is-scrolled {
    background: rgba(247, 245, 239, 0.85);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom-color: var(--line);
  }

  .header__inner {
    max-width: var(--container);
    margin-inline: auto;
    padding: 20px var(--pad-x);
    display: flex;
    align-items: center;
    gap: 40px;
  }

  .header__brand {
    display: inline-flex;
    flex-direction: column;
    gap: 4px;
    white-space: nowrap;
  }

  .header__brand-name {
    font-weight: 700;
    font-size: 18px;
    letter-spacing: 0.18em;
    line-height: 1;
  }

  .header__brand-line {
    width: 96px;
    height: 9px;
    display: block;
  }

  .header__nav {
    display: flex;
    gap: 28px;
    margin-left: auto;
  }

  .header__nav a {
    font-size: 13px;
    letter-spacing: 0.1em;
    color: var(--c-sub);
    transition: color 0.3s ease;
  }

  .header__nav a:hover {
    color: var(--c-text);
  }

  .header__cta {
    font-size: 13px;
    letter-spacing: 0.12em;
    border: 1px solid var(--c-text);
    color: var(--c-text);
    background: transparent;
    border-radius: 999px;
    padding: 10px 24px;
    white-space: nowrap;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  .header__cta:hover {
    background: var(--c-text);
    color: var(--c-base);
  }

  @media (max-width: 900px) {
    .header__nav {
      display: none;
    }
    .header__cta {
      margin-left: auto;
    }
  }

  @media (max-width: 480px) {
    .header__inner {
      padding-block: 16px;
      gap: 16px;
    }
    .header__brand {
      font-size: 15px;
    }
    .header__cta {
      font-size: 12px;
      padding: 8px 14px;
    }
  }

  @media (max-width: 360px) {
    .header__inner {
      padding-inline: 16px;
      gap: 12px;
    }
    .header__brand {
      font-size: 13px;
    }
    .header__cta {
      font-size: 11px;
      padding: 6px 10px;
      letter-spacing: 0.06em;
    }
  }
</style>
