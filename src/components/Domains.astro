---
interface Props {
  label?: string;
}

const { label = "02 / Domains" } = Astro.props;

const domains = [
  {
    num: "01",
    en: "Front Office",
    ja: "顧客接点を整える",
    body: [
      "営業、顧客管理、案件管理、問い合わせ、見積、受注、営業会議を整理します。",
      "CRM/SFAを必要に応じて活用し、営業活動が見える状態をつくります。",
    ],
  },
  {
    num: "02",
    en: "Back Office",
    ja: "社内業務を整える",
    body: [
      "経理、人事、総務、契約、請求、勤怠、経費、申請・承認などを整理します。",
      "手作業、二重入力、属人化を減らし、少ない人数でも回る業務フローをつくります。",
    ],
  },
  {
    num: "03",
    en: "Management",
    ja: "経営判断を整える",
    body: [
      "売上、粗利、案件状況、工数、請求、入金、KPIなどを整理します。",
      "経営判断に必要な数字が自然に集まる状態をつくります。",
    ],
  },
];
---

<section class="section domains" id="domains">
  <div class="container">
    <p class="en-label reveal">{label}</p>
    <h2 class="heading-ja domains__heading reveal" style="--reveal-delay: 0.1s">
      支援領域
    </h2>
    <p class="lead domains__lead reveal" style="--reveal-delay: 0.2s">
      顧客接点、社内業務、経営判断。3つの領域で、会社の仕事の流れを整えます。
    </p>

    <div class="domains__panels">
      {
        domains.map((domain) => (
          <article class="domains__panel reveal">
            <div class="domains__meta">
              <span class="domains__num">{domain.num}</span>
              <span class="domains__en">{domain.en}</span>
            </div>
            <h3 class="domains__ja">{domain.ja}</h3>
            <div class="domains__body">
              {domain.body.map((paragraph) => (
                <p>{paragraph}</p>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .domains {
    background: var(--c-black);
  }

  .domains__heading {
    margin-top: 36px;
  }

  .domains__lead {
    margin-top: 32px;
  }

  /* --- 3つの大型パネル --- */
  .domains__panels {
    margin-top: 112px;
  }

  .domains__panel {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    column-gap: clamp(32px, 5vw, 96px);
    row-gap: 28px;
    padding-block: clamp(64px, 8vw, 112px);
    border-top: 1px solid var(--line);
  }

  .domains__panel:last-child {
    border-bottom: 1px solid var(--line);
  }

  .domains__meta {
    grid-column: 1;
    display: flex;
    align-items: baseline;
    gap: 20px;
  }

  .domains__num {
    font-family: var(--font-en);
    font-weight: 200;
    font-size: 13px;
    letter-spacing: 0.2em;
    color: var(--c-gold);
  }

  .domains__en {
    font-family: var(--font-en);
    font-weight: 400;
    font-size: 12px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--c-muted);
  }

  /* 日本語を主役にした見出し */
  .domains__ja {
    grid-column: 1;
    font-size: clamp(26px, 3.6vw, 44px);
    font-weight: 400;
    letter-spacing: 0.1em;
    line-height: 1.6;
  }

  .domains__body {
    grid-column: 2;
    grid-row: 1 / 3;
    align-self: center;
    max-width: 480px;
  }

  .domains__body p {
    font-size: 14.5px;
    line-height: 2.3;
    color: var(--c-muted);
  }

  .domains__body p + p {
    margin-top: 1.4em;
  }

  @media (max-width: 960px) {
    .domains__panel {
      grid-template-columns: 1fr;
    }

    .domains__body {
      grid-column: 1;
      grid-row: auto;
      margin-top: 8px;
    }
  }
</style>
