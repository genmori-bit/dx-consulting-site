---
interface Props {
  label?: string;
  /** 「よくある相談例」を表示する(/services/ で使用) */
  showExamples?: boolean;
}

const { label = "02 / Domains", showExamples = false } = Astro.props;

const domains = [
  {
    num: "01",
    en: "Front Office",
    ja: "顧客接点を整える",
    tone: "blue",
    body: [
      "営業、顧客管理、案件管理、問い合わせ、見積、受注、営業会議を整理します。",
      "CRM/SFAを必要に応じて活用し、営業活動が見える状態をつくります。",
    ],
    example:
      "営業案件をExcelで管理していて、案件状況や次アクションが見えない。",
  },
  {
    num: "02",
    en: "Back Office",
    ja: "社内業務を整える",
    tone: "green",
    body: [
      "経理、人事、総務、契約、請求、勤怠、経費、申請・承認などを整理します。",
      "手作業、二重入力、属人化を減らし、少ない人数でも回る業務フローをつくります。",
    ],
    example:
      "請求、申請、承認、経費精算が人によって違い、確認作業に時間がかかっている。",
  },
  {
    num: "03",
    en: "Management",
    ja: "経営判断を整える",
    tone: "orange",
    body: [
      "売上、粗利、案件状況、工数、請求、入金、KPIなどを整理します。",
      "経営判断に必要な数字が自然に集まる状態をつくります。",
    ],
    example:
      "売上、粗利、案件見込み、入金状況が別々の場所にあり、会議のたびに集計している。",
  },
];
---

<section class="section domains" id="domains">
  <div class="container">
    <p class="en-label reveal">{label}</p>
    <h2 class="heading-ja domains__heading reveal" style="--reveal-delay: 0.1s">
      整えるのは、会社の3つの流れ。
    </h2>
    <p class="lead domains__lead reveal" style="--reveal-delay: 0.2s">
      顧客接点、社内業務、経営判断。3つの領域で、会社の仕事の流れを整えます。
    </p>

    <!-- 道筋:一本の線が3方向へ分岐する -->
    <svg
      class="domains__fork reveal"
      viewBox="0 0 220 92"
      fill="none"
      aria-hidden="true"
    >
      <path class="fork fork--stem" d="M 110 2 V 26"></path>
      <path class="fork fork--b" d="M 110 26 C 110 50, 32 52, 24 88"></path>
      <path class="fork fork--b" style="--fd: 0.5s" d="M 110 26 V 88"></path>
      <path
        class="fork fork--b"
        style="--fd: 0.6s"
        d="M 110 26 C 110 50, 188 52, 196 88"></path>
    </svg>

    <!-- 3枚の紙面が少し重なる -->
    <div class="domains__stack">
      {
        domains.map((domain, i) => (
          <article
            class:list={["domains__paper", `domains__paper--${domain.tone}`, "reveal"]}
            style={`--reveal-delay: ${i * 0.12}s`}
          >
            <span class="domains__tab" aria-hidden="true" />
            <div class="domains__meta">
              <span class="domains__num">{domain.num}</span>
              <span class="domains__en">{domain.en}</span>
            </div>
            <h3 class="domains__ja">{domain.ja}</h3>
            <div class="domains__body">
              {domain.body.map((paragraph) => (
                <p>{paragraph}</p>
              ))}
            </div>
            {showExamples && (
              <div class="domains__example">
                <span class="domains__example-label">よくある相談例</span>
                <p class="domains__example-body">「{domain.example}」</p>
              </div>
            )}
            <span class="domains__rule" aria-hidden="true" />
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .domains {
    background: var(--c-base);
  }

  .domains__heading {
    margin-top: 36px;
  }

  .domains__lead {
    margin-top: 32px;
  }

  /* --- 分岐する道筋 --- */
  .domains__fork {
    display: block;
    width: 200px;
    height: 84px;
    margin-top: 72px;
  }

  .fork {
    stroke: rgba(255, 90, 31, 0.85);
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-dasharray: 130;
    stroke-dashoffset: 130;
    transition: stroke-dashoffset 0.9s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--fd, 0.4s);
  }

  .fork--stem {
    transition-delay: 0.15s;
  }

  .domains__fork.is-visible .fork {
    stroke-dashoffset: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .fork {
      transition: none;
      stroke-dashoffset: 0;
    }
  }

  @media (max-width: 720px) {
    .domains__fork {
      display: none;
    }
  }

  /* --- 重なる紙面 --- */
  .domains__stack {
    margin-top: 56px;
    display: flex;
    flex-direction: column;
  }

  .domains__paper {
    position: relative;
    width: min(100%, 860px);
    background: var(--c-white);
    border: 1px solid var(--c-hairline);
    border-radius: var(--radius);
    box-shadow: var(--shadow-paper);
    padding: clamp(32px, 5vw, 64px);
    transition-property: opacity, transform, translate, rotate, box-shadow;
  }

  .domains__paper:nth-child(1) {
    align-self: flex-start;
    rotate: -0.6deg;
    z-index: 1;
  }

  .domains__paper:nth-child(2) {
    align-self: center;
    margin-top: -44px;
    rotate: 0.5deg;
    z-index: 2;
  }

  .domains__paper:nth-child(3) {
    align-self: flex-end;
    margin-top: -44px;
    rotate: -0.4deg;
    z-index: 3;
  }

  /* ホバー:紙片が少し浮き、下の線が伸びる */
  @media (hover: hover) {
    .domains__paper {
      transition: opacity 1.1s cubic-bezier(0.16, 1, 0.3, 1),
        transform 1.1s cubic-bezier(0.16, 1, 0.3, 1), translate 0.5s ease,
        rotate 0.5s ease, box-shadow 0.5s ease;
      transition-delay: var(--reveal-delay, 0s), var(--reveal-delay, 0s), 0s,
        0s, 0s;
    }

    .domains__paper:hover {
      translate: 0 -6px;
      rotate: 0deg;
      box-shadow: 0 22px 56px rgba(17, 17, 17, 0.1);
      z-index: 4;
    }

    .domains__paper:hover .domains__rule {
      transform: scaleX(1);
    }
  }

  /* 付箋タブ */
  .domains__tab {
    position: absolute;
    top: -9px;
    left: 36px;
    width: 58px;
    height: 18px;
    border-radius: 5px;
    rotate: -2deg;
    opacity: 0.85;
  }

  /* タブは色分類をやめ、紙のインデックスとして中立色に統一 */
  .domains__tab {
    background: rgba(17, 17, 17, 0.1);
  }

  .domains__meta {
    display: flex;
    align-items: baseline;
    gap: 18px;
  }

  .domains__num {
    font-family: var(--font-en);
    font-weight: 300;
    font-size: 13px;
    letter-spacing: 0.2em;
  }

  .domains__num { color: var(--c-primary); }

  .domains__en {
    font-family: var(--font-en);
    font-weight: 400;
    font-size: 12px;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: var(--c-sub);
  }

  .domains__ja {
    margin-top: 20px;
    font-size: clamp(22px, 2.8vw, 32px);
    font-weight: 400;
    letter-spacing: 0.1em;
    line-height: 1.7;
  }

  .domains__body {
    margin-top: 24px;
    max-width: 560px;
  }

  .domains__body p {
    font-size: 14px;
    line-height: 2.2;
    color: var(--c-sub);
  }

  .domains__body p + p {
    margin-top: 1.2em;
  }

  /* よくある相談例(付箋風のメモ) */
  .domains__example {
    margin-top: 28px;
    max-width: 560px;
    background: var(--c-base);
    border: 1px solid var(--c-hairline);
    border-radius: 8px;
    padding: 18px 22px;
  }

  .domains__example { border-left: 2px solid var(--c-primary); }

  .domains__example-label {
    display: block;
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--c-sub);
  }

  .domains__example-body {
    margin-top: 8px;
    font-size: 13.5px;
    line-height: 2;
    letter-spacing: 0.06em;
  }

  /* ホバーで伸びる細い線 */
  .domains__rule {
    position: absolute;
    left: clamp(32px, 5vw, 64px);
    right: clamp(32px, 5vw, 64px);
    bottom: 24px;
    height: 1px;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .domains__rule { background: var(--c-primary); }

  @media (max-width: 840px) {
    .domains__stack {
      gap: 20px;
    }

    .domains__paper:nth-child(2),
    .domains__paper:nth-child(3) {
      margin-top: 0;
    }

    .domains__paper {
      width: 100%;
    }
  }
</style>
