---
interface Props {
  label?: string;
}

const { label = "02 / Domains" } = Astro.props;

const domains = [
  {
    num: "01",
    en: "Front Office",
    ja: "顧客接点を整える",
    body: [
      "営業、顧客管理、案件管理、問い合わせ、見積、受注、営業会議を整理します。",
      "CRM/SFAを必要に応じて活用し、営業活動が見える状態をつくります。",
    ],
  },
  {
    num: "02",
    en: "Back Office",
    ja: "社内業務を整える",
    body: [
      "経理、人事、総務、契約、請求、勤怠、経費、申請・承認などを整理します。",
      "手作業、二重入力、属人化を減らし、少ない人数でも回る業務フローをつくります。",
    ],
  },
  {
    num: "03",
    en: "Management",
    ja: "経営判断を整える",
    body: [
      "売上、粗利、案件状況、工数、請求、入金、KPIなどを整理します。",
      "経営判断に必要な数字が自然に集まる状態をつくります。",
    ],
  },
];
---

<section class="section domains" id="domains">
  <div class="container">
    <p class="en-label reveal">{label}</p>
    <h2 class="heading-ja domains__heading reveal" style="--reveal-delay: 0.1s">
      支援領域
    </h2>
    <p class="lead domains__lead reveal" style="--reveal-delay: 0.2s">
      顧客接点、社内業務、経営判断。3つの領域で、会社の仕事の流れを整えます。
    </p>

    <div class="domains__stage" data-domains-stage>
      <!-- 左:固定される大型英字(現在の領域が明るくなる) -->
      <div class="domains__stick" aria-hidden="true">
        <ol class="domains__stick-list">
          {
            domains.map((domain, i) => (
              <li class:list={["domains__stick-item", { "is-active": i === 0 }]} data-stick-item>
                <span class="domains__stick-num">{domain.num}</span>
                <span class="domains__stick-en en-display">{domain.en}</span>
              </li>
            ))
          }
        </ol>
      </div>

      <!-- 右:スクロールで流れる本文 -->
      <div class="domains__flow">
        {
          domains.map((domain, i) => (
            <article class="domains__block reveal" data-domain-block data-index={i}>
              <p class="domains__mobile-en">
                {domain.num} — {domain.en}
              </p>
              <h3 class="domains__ja">{domain.ja}</h3>
              <div class="domains__body">
                {domain.body.map((paragraph) => (
                  <p>{paragraph}</p>
                ))}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  // 右側のブロックが画面中央帯に入ったら、左の英字を切り替える(スクロールジャックなし)
  const stages = document.querySelectorAll<HTMLElement>("[data-domains-stage]");

  stages.forEach((stage) => {
    const stickItems = stage.querySelectorAll<HTMLElement>("[data-stick-item]");
    const blocks = stage.querySelectorAll<HTMLElement>("[data-domain-block]");
    if (!stickItems.length || !blocks.length) return;

    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          const index = Number((entry.target as HTMLElement).dataset.index);
          stickItems.forEach((item, i) =>
            item.classList.toggle("is-active", i === index)
          );
        }
      },
      { rootMargin: "-40% 0px -50% 0px" }
    );

    blocks.forEach((block) => io.observe(block));
  });
</script>

<style>
  .domains {
    background: var(--c-black);
  }

  .domains__heading {
    margin-top: 36px;
  }

  .domains__lead {
    margin-top: 32px;
  }

  .domains__stage {
    margin-top: 112px;
    display: grid;
    grid-template-columns: 1fr 1.05fr;
    gap: clamp(48px, 6vw, 112px);
    align-items: start;
  }

  /* --- 左:スティッキーな大型英字 --- */
  .domains__stick {
    position: sticky;
    top: 24vh;
  }

  .domains__stick-list {
    list-style: none;
  }

  .domains__stick-item {
    padding-block: 26px;
    border-top: 1px solid var(--line);
    opacity: 0.16;
    transition: opacity 0.7s ease;
  }

  .domains__stick-item:last-child {
    border-bottom: 1px solid var(--line);
  }

  .domains__stick-item.is-active {
    opacity: 1;
  }

  .domains__stick-num {
    font-family: var(--font-en);
    font-weight: 200;
    font-size: 13px;
    letter-spacing: 0.2em;
    color: var(--c-gold);
  }

  .domains__stick-en {
    display: block;
    margin-top: 8px;
    font-size: clamp(34px, 4.2vw, 60px);
    font-weight: 200;
  }

  /* --- 右:本文 --- */
  .domains__block {
    padding-block: clamp(64px, 9vw, 120px);
    border-top: 1px solid var(--line);
  }

  .domains__block:last-child {
    border-bottom: 1px solid var(--line);
  }

  .domains__mobile-en {
    display: none;
  }

  .domains__ja {
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 400;
    letter-spacing: 0.1em;
    line-height: 1.7;
  }

  .domains__body {
    margin-top: 32px;
    max-width: 460px;
  }

  .domains__body p {
    font-size: 14.5px;
    line-height: 2.3;
    color: var(--c-muted);
  }

  .domains__body p + p {
    margin-top: 1.4em;
  }

  /* --- スマホ:縦に流れる通常レイアウト --- */
  @media (max-width: 960px) {
    .domains__stage {
      grid-template-columns: 1fr;
    }

    .domains__stick {
      display: none;
    }

    .domains__mobile-en {
      display: block;
      font-family: var(--font-en);
      font-weight: 400;
      font-size: 12px;
      letter-spacing: 0.26em;
      text-transform: uppercase;
      color: var(--c-muted);
      margin-bottom: 20px;
    }

    .domains__block {
      padding-block: clamp(48px, 8vw, 72px);
    }
  }
</style>
