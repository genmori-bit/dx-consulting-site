---
import OperationsMap from "./OperationsMap.astro";
---

<section class="hero" id="top">
  <div class="hero__bg" aria-hidden="true"></div>

  <div class="container hero__inner">
    <p class="en-label reveal">Operations / Data / Systems</p>

    <h1 class="hero__title en-display">
      <span class="hero__line">
        <span class="hero__line-inner">Business,</span>
      </span>
      <span class="hero__line">
        <span class="hero__line-inner hero__line-inner--2 hero__title-accent"
          >Re-designed.</span
        >
      </span>
    </h1>

    <div class="hero__row">
      <div class="hero__copywrap">
        <p class="hero__copy reveal" style="--reveal-delay: 0.75s">
          事業が動く仕組みを、設計する。
        </p>

        <p class="hero__sub reveal" style="--reveal-delay: 0.9s">
          営業、管理部門、経営判断。<br />
          会社の中で分断された仕事の流れを整え、<br class="pc-only" />
          デジタルが現場で自然に使われる状態をつくります。
        </p>

        <div class="hero__actions reveal" style="--reveal-delay: 1.05s">
          <a href="#contact" class="btn btn--primary cta-flow"
            >相談する<span class="cta-arrow" aria-hidden="true">→</span></a
          >
          <a href="#domains" class="btn btn--ghost cta-flow"
            >支援内容を見る<span class="cta-arrow" aria-hidden="true">→</span></a
          >
        </div>
      </div>

      <figure class="hero__map reveal" style="--reveal-delay: 0.5s">
        <OperationsMap />
        <figcaption>Operations Map — 業務とデータの流れ</figcaption>
      </figure>
    </div>
  </div>

  <div class="hero__scroll" aria-hidden="true">
    <span>Scroll</span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--c-black);
  }

  /* --- 背景:ごく薄いグリッドのみ(グローなし)。ごくゆっくり漂う --- */
  .hero__bg {
    position: absolute;
    inset: -140px;
    background-image: linear-gradient(var(--line) 1px, transparent 1px),
      linear-gradient(90deg, var(--line) 1px, transparent 1px);
    background-size: 120px 120px;
    animation: grid-drift 90s linear infinite alternate;
    mask-image: radial-gradient(
      120% 90% at 70% 40%,
      rgba(0, 0, 0, 0.28),
      transparent 70%
    );
    -webkit-mask-image: radial-gradient(
      120% 90% at 70% 40%,
      rgba(0, 0, 0, 0.28),
      transparent 70%
    );
  }

  /* --- コンテンツ --- */
  .hero__inner {
    position: relative;
    width: 100%;
    padding-top: 140px;
    padding-bottom: 96px;
  }

  .hero__title {
    font-size: clamp(60px, 13.5vw, 192px);
    font-weight: 200;
    color: var(--c-ink);
  }

  /* 行ごとに下から静かに組み上がる */
  .hero__line {
    display: block;
    overflow: hidden;
    /* ディセンダー(g等)が切れないよう余白を確保 */
    padding-bottom: 0.12em;
    margin-bottom: -0.12em;
  }

  .hero__line-inner {
    display: block;
    transform: translateY(112%);
    animation: hero-rise 1.3s cubic-bezier(0.16, 1, 0.3, 1) 0.15s forwards;
  }

  .hero__line-inner--2 {
    animation-delay: 0.4s;
  }

  .hero__title-accent {
    color: transparent;
    -webkit-text-stroke: 1px rgba(238, 236, 230, 0.85);
  }

  @keyframes hero-rise {
    to {
      transform: translateY(0);
    }
  }

  @keyframes grid-drift {
    to {
      transform: translate3d(120px, 120px, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__bg {
      animation: none;
    }
    .hero__line-inner {
      animation: none;
      transform: none;
    }
  }

  .hero__row {
    margin-top: clamp(56px, 7vw, 96px);
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(48px, 6vw, 112px);
    align-items: end;
  }

  .hero__copy {
    font-size: clamp(17px, 2.2vw, 22px);
    font-weight: 500;
    letter-spacing: 0.14em;
  }

  .hero__sub {
    margin-top: 28px;
    font-size: 14px;
    line-height: 2.3;
    color: var(--c-muted);
    max-width: 560px;
  }

  .hero__actions {
    margin-top: 64px;
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
  }

  .btn {
    font-size: 14px;
    letter-spacing: 0.14em;
    white-space: nowrap;
    padding: 16px 40px;
    border: 1px solid;
    transition: background-color 0.35s ease, color 0.35s ease,
      border-color 0.35s ease;
  }

  .btn--primary {
    background: transparent;
    border-color: var(--c-gold-dim);
    color: var(--c-gold);
  }

  .btn--primary:hover {
    background: var(--c-gold);
    border-color: var(--c-gold);
    color: var(--c-black);
  }

  .btn--ghost {
    border-color: var(--line);
    color: var(--c-ink);
  }

  .btn--ghost:hover {
    border-color: var(--c-ink);
  }

  /* --- Operations Map --- */
  .hero__map {
    max-width: 560px;
    justify-self: end;
    width: 100%;
  }

  .hero__map figcaption {
    margin-top: 20px;
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--c-muted);
    border-top: 1px solid var(--line);
    padding-top: 14px;
  }

  /* --- スクロールインジケーター --- */
  .hero__scroll {
    position: absolute;
    bottom: 0;
    left: var(--pad-x);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .hero__scroll span {
    font-family: var(--font-en);
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-muted);
    writing-mode: vertical-rl;
  }

  .hero__scroll::after {
    content: "";
    width: 1px;
    height: 64px;
    background: linear-gradient(var(--c-gold-dim), transparent);
  }

  @media (max-width: 960px) {
    .hero__row {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .hero__map {
      justify-self: start;
      max-width: 480px;
      margin-top: 16px;
    }

    /* 1カラム時はマップのキャプションと重なるため非表示 */
    .hero__scroll {
      display: none;
    }
  }

  @media (max-width: 720px) {
    .pc-only {
      display: none;
    }
    .hero__scroll {
      display: none;
    }
    .hero__inner {
      padding-top: 120px;
    }
    .btn {
      flex: 1;
      text-align: center;
      padding-inline: 20px;
    }
  }
</style>
