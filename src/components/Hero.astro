---
/**
 * Hero — The Workflow Untangles.
 * コピーは左、右にはMichi Map(散らばった業務が道筋に変わる業務地図)。
 * 地図の実装は HeroMichiMap.astro に分離。
 */
import HeroMichiMap from "./HeroMichiMap.astro";
---

<section class="hero" id="top">
  <div class="hero__bg" aria-hidden="true"></div>

  <div class="container hero__inner">
    <p class="en-label reveal">散らばった仕事に、道筋を。</p>

    <h1 class="hero__title en-display">
      <span class="hero__line">
        <span class="hero__line-inner">Workflows,</span>
      </span>
      <span class="hero__line">
        <span class="hero__line-inner hero__line-inner--2 hero__title-accent"
          >Re-designed.</span
        >
      </span>
    </h1>

    <div class="hero__row">
      <div class="hero__copywrap">
        <p class="hero__copy reveal" style="--reveal-delay: 0.5s">
          仕事の流れを、整える。
        </p>

        <p class="hero__sub reveal" style="--reveal-delay: 0.62s">
          営業、管理部門、経営判断。<br />
          会社の中に散らばった業務と情報をつなぎ、<br class="pc-only" />
          少ない人数でも前に進める仕組みをつくります。
        </p>

        <div class="hero__actions reveal" style="--reveal-delay: 0.75s">
          <a href="#contact" class="btn btn--primary cta-flow"
            >話してみる<span class="cta-arrow" aria-hidden="true">→</span></a
          >
          <a href="#domains" class="btn btn--ghost cta-flow"
            >支援内容を見る<span class="cta-arrow" aria-hidden="true">→</span></a
          >
        </div>
      </div>

      <HeroMichiMap />
    </div>
  </div>

  <div class="hero__scroll" aria-hidden="true">
    <span>Scroll</span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--c-base);
  }

  /* --- 背景:薄い方眼紙 --- */
  .hero__bg {
    position: absolute;
    inset: 0;
    background-image: linear-gradient(
        rgba(222, 222, 216, 0.45) 1px,
        transparent 1px
      ),
      linear-gradient(90deg, rgba(222, 222, 216, 0.45) 1px, transparent 1px),
      linear-gradient(rgba(222, 222, 216, 0.22) 1px, transparent 1px),
      linear-gradient(90deg, rgba(222, 222, 216, 0.22) 1px, transparent 1px);
    background-size: 120px 120px, 120px 120px, 24px 24px, 24px 24px;
    mask-image: radial-gradient(
      130% 100% at 60% 40%,
      rgba(0, 0, 0, 0.7),
      transparent 75%
    );
    -webkit-mask-image: radial-gradient(
      130% 100% at 60% 40%,
      rgba(0, 0, 0, 0.7),
      transparent 75%
    );
  }

  /* --- コンテンツ --- */
  .hero__inner {
    position: relative;
    z-index: 1;
    width: 100%;
    padding-top: 116px;
    padding-bottom: 80px;
  }

  /* ファーストビューにCTAとMichi Mapが収まるサイズ */
  .hero__title {
    font-size: clamp(48px, 9.5vw, 118px);
    font-weight: 200;
    color: var(--c-text);
  }

  .hero__line {
    display: block;
    overflow: hidden;
    padding-bottom: 0.12em;
    margin-bottom: -0.12em;
  }

  .hero__line-inner {
    display: block;
    transform: translateY(112%);
    animation: hero-rise 1.3s cubic-bezier(0.16, 1, 0.3, 1) 0.15s forwards;
  }

  .hero__line-inner--2 {
    animation-delay: 0.4s;
  }

  .hero__title-accent {
    color: transparent;
    -webkit-text-stroke: 1px rgba(17, 17, 17, 0.75);
  }

  @keyframes hero-rise {
    to {
      transform: translateY(0);
    }
  }

  .hero__row {
    margin-top: clamp(36px, 4vw, 52px);
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(380px, 540px);
    gap: clamp(48px, 6vw, 104px);
    align-items: start;
  }

  .hero__copywrap {
    max-width: 560px;
  }

  .hero__copy {
    font-size: clamp(17px, 2.2vw, 22px);
    font-weight: 500;
    letter-spacing: 0.14em;
  }

  .hero__sub {
    margin-top: 28px;
    font-size: 14px;
    line-height: 2.3;
    color: var(--c-sub);
  }

  .hero__actions {
    margin-top: 52px;
    display: flex;
    gap: 18px;
    flex-wrap: wrap;
  }

  .btn {
    font-size: 14px;
    letter-spacing: 0.14em;
    white-space: nowrap;
    padding: 16px 38px;
    border-radius: 10px;
    border: 1px solid;
    transition: background-color 0.35s ease, color 0.35s ease,
      border-color 0.35s ease, translate 0.35s ease;
  }

  /* Primary CTA:焼きオレンジ */
  .btn--primary {
    background: var(--c-primary);
    border-color: var(--c-primary);
    color: #fff;
    font-weight: 500;
  }

  .btn--primary:hover {
    background: var(--c-primary-dark);
    border-color: var(--c-primary-dark);
    translate: 0 -2px;
  }

  /* Secondary CTA:透明+墨の枠 */
  .btn--ghost {
    background: transparent;
    border-color: var(--c-text);
    color: var(--c-text);
  }

  .btn--ghost:hover {
    background: var(--c-text);
    color: #fff;
    translate: 0 -2px;
  }

  /* --- スクロールインジケーター --- */
  .hero__scroll {
    position: absolute;
    bottom: 0;
    left: var(--pad-x);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .hero__scroll span {
    font-family: var(--font-en);
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-sub);
    writing-mode: vertical-rl;
  }

  .hero__scroll::after {
    content: "";
    width: 1px;
    height: 64px;
    background: linear-gradient(var(--c-hairline), transparent);
  }

  @media (max-width: 960px) {
    .hero__row {
      grid-template-columns: 1fr;
    }

    .hero__scroll {
      display: none;
    }
  }

  @media (max-width: 720px) {
    .pc-only {
      display: none;
    }

    .hero__inner {
      padding-top: 116px;
    }

    .btn {
      flex: 1;
      text-align: center;
      padding-inline: 20px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__line-inner {
      animation: none;
      transform: none;
    }
  }
</style>
