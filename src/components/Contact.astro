---
/**
 * Contact — SNSへの連絡導線(フォーム・メールは設置しない)。
 * facebookUrl が空のときは、Facebookボタンを表示しない。
 */
import { SITE } from "../config";
---

<section class="section contact" id="contact">
  <div class="container">
    <p class="en-label reveal">07 / Contact</p>

    <h2 class="heading-ja contact__heading reveal" style="--reveal-delay: 0.1s">
      まずは、SNSで気軽にご連絡ください。
    </h2>

    <p class="contact__lead reveal" style="--reveal-delay: 0.2s">
      業務改善やAI活用について、まだ相談内容がまとまっていなくても構いません。
      LinkedInまたはFacebookのメッセージからご連絡ください。
    </p>

    <div class="contact__actions reveal" style="--reveal-delay: 0.32s">
      <a
        href={SITE.linkedinUrl}
        class="contact__cta contact__cta--primary"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedInで連絡する(新しいタブで開きます)"
        >LinkedInで連絡する<span class="cta-arrow" aria-hidden="true">→</span></a
      >
      {
        SITE.facebookUrl && (
          <a
            href={SITE.facebookUrl}
            class="contact__cta contact__cta--secondary"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebookで連絡する(新しいタブで開きます)"
          >
            Facebookで連絡する
            <span class="cta-arrow" aria-hidden="true">→</span>
          </a>
        )
      }
    </div>
  </div>
</section>

<style>
  /* 墨黒の強い締めセクション */
  .contact {
    background: var(--c-text);
    color: var(--c-base);
  }

  .contact .en-label {
    color: rgba(248, 248, 246, 0.7);
  }

  .contact .en-label::before {
    background: rgba(248, 248, 246, 0.4);
  }

  .contact__heading {
    margin-top: 36px;
    color: #fff;
  }

  .contact__lead {
    margin-top: 40px;
    font-size: 14.5px;
    line-height: 2.4;
    color: rgba(248, 248, 246, 0.82);
    max-width: 520px;
  }

  .contact__actions {
    margin-top: 64px;
    display: flex;
    gap: 18px;
    flex-wrap: wrap;
  }

  .contact__cta {
    display: inline-flex;
    align-items: center;
    padding: 17px 40px;
    border-radius: 10px;
    font-size: 14px;
    letter-spacing: 0.12em;
    transition: background-color 0.35s ease, border-color 0.35s ease,
      color 0.35s ease, translate 0.35s ease;
  }

  .contact__cta .cta-arrow {
    margin-left: 12px;
    transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .contact__cta:hover .cta-arrow {
    transform: translateX(5px);
  }

  /* Primary:焼きオレンジ */
  .contact__cta--primary {
    background: var(--c-primary);
    border: 1px solid var(--c-primary);
    color: #fff;
    font-weight: 500;
  }

  .contact__cta--primary:hover {
    background: var(--c-primary-dark);
    border-color: var(--c-primary-dark);
    translate: 0 -2px;
  }

  /* Secondary:透明+白枠(墨黒面のため) */
  .contact__cta--secondary {
    background: transparent;
    border: 1px solid rgba(248, 248, 246, 0.55);
    color: #fff;
  }

  .contact__cta--secondary:hover {
    border-color: #fff;
    translate: 0 -2px;
  }

  @media (max-width: 640px) {
    .contact__cta {
      flex: 1 1 100%;
      justify-content: center;
    }
  }
</style>
