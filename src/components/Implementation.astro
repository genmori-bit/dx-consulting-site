---
interface Props {
  label?: string;
}

const { label = "03 / Implementation" } = Astro.props;

const items = [
  {
    num: "01",
    title: "業務設計",
    body: "業務フロー、役割分担、承認ルール、入力ルールを整理します。",
  },
  {
    num: "02",
    title: "データ設計",
    body: "顧客、案件、売上、請求、工数など、見るべき情報を整えます。",
  },
  {
    num: "03",
    title: "システム設計",
    body: "CRM/SFA、会計、労務、勤怠、請求、契約、グループウェアなどの業務システムを、業務に合わせて設計します。",
  },
  {
    num: "04",
    title: "自動化・AI活用",
    body: "生成AI、ワークフロー自動化、通知、集計、ナレッジ活用を業務に組み込みます。",
  },
  {
    num: "05",
    title: "定着支援",
    body: "マニュアル、社内教育、運用会議、改善サイクルまで整えます。",
  },
];
---

<section class="section implementation" id="implementation">
  <div class="container">
    <p class="en-label reveal">{label}</p>
    <h2 class="heading-ja implementation__heading reveal" style="--reveal-delay: 0.1s">
      何を、どこまでやるか
    </h2>
    <p class="lead implementation__lead reveal" style="--reveal-delay: 0.2s">
      支援領域を問わず、この5つを組み合わせて進めます。
      設計だけで終わらせず、日々の運用まで含めて支援範囲です。
    </p>

    <ol class="implementation__list">
      {
        items.map((item, i) => (
          <li class="implementation__row reveal" style={`--reveal-delay: ${i * 0.08}s`}>
            <span class="implementation__num">{item.num}</span>
            <h3 class="implementation__title">{item.title}</h3>
            <p class="implementation__body">{item.body}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .implementation {
    background: var(--c-charcoal);
    border-block: 1px solid var(--line);
  }

  .implementation__heading {
    margin-top: 36px;
  }

  .implementation__lead {
    margin-top: 32px;
  }

  .implementation__list {
    margin-top: 112px;
    list-style: none;
  }

  .implementation__row {
    display: grid;
    grid-template-columns: 90px 1fr 1.5fr;
    gap: clamp(20px, 3vw, 48px);
    align-items: baseline;
    padding-block: clamp(36px, 4.5vw, 56px);
    border-top: 1px solid var(--line);
  }

  .implementation__row:last-child {
    border-bottom: 1px solid var(--line);
  }

  /* ホバー:わずかに浮き、罫線が少し明るくなる */
  @media (hover: hover) {
    .implementation__row:hover {
      translate: 0 -3px;
      border-top-color: rgba(238, 236, 230, 0.32);
    }
  }

  .implementation__num {
    font-family: var(--font-en);
    font-weight: 200;
    font-size: 13px;
    letter-spacing: 0.2em;
    color: var(--c-gold);
  }

  .implementation__title {
    font-size: clamp(17px, 2vw, 21px);
    font-weight: 400;
    letter-spacing: 0.12em;
  }

  .implementation__body {
    font-size: 14px;
    line-height: 2.3;
    color: var(--c-muted);
  }

  @media (max-width: 840px) {
    .implementation__row {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }
</style>
