---
interface Props {
  label?: string;
}

const { label = "04 / Implementation" } = Astro.props;

const items = [
  {
    num: "01",
    phase: "設計",
    title: "業務設計",
    body: "業務フロー、役割分担、承認ルール、入力ルールを整理します。",
  },
  {
    num: "02",
    phase: "",
    title: "データ設計",
    body: "顧客、案件、売上、請求、工数など、見るべき情報を整えます。",
  },
  {
    num: "03",
    phase: "",
    title: "システム設計",
    body: "CRM/SFA、会計、労務、勤怠、請求、契約、グループウェアなどの業務システムを、業務に合わせて設計します。",
  },
  {
    num: "04",
    phase: "実装",
    title: "自動化・AI活用",
    body: "生成AI、ワークフロー自動化、通知、集計、ナレッジ活用を業務に組み込みます。",
  },
  {
    num: "05",
    phase: "定着",
    title: "定着支援",
    body: "マニュアル、社内教育、運用会議、改善サイクルまで整えます。",
  },
];
---

<section class="section impl" id="implementation">
  <div class="container">
    <p class="en-label reveal">{label}</p>
    <h2 class="heading-ja impl__heading reveal" style="--reveal-delay: 0.1s">
      仕組みになるまで、設計する。
    </h2>
    <p class="lead impl__lead reveal" style="--reveal-delay: 0.2s">
      支援領域を問わず、この5つを組み合わせて進めます。
      設計で終わらせず、日々の運用まで含めて支援範囲です。
    </p>

    <!-- 道筋:3つの流れが合流し、5つの工程を通る -->
    <svg
      class="impl__merge reveal"
      viewBox="0 0 300 64"
      fill="none"
      aria-hidden="true"
    >
      <path class="mg mg--in" d="M 2 6 C 60 6, 76 30, 122 31"></path>
      <path class="mg mg--in" style="--md: 0.3s" d="M 2 31 H 122"></path>
      <path class="mg mg--in" style="--md: 0.4s" d="M 2 56 C 60 56, 76 32, 122 31"></path>
      <path class="mg mg--trunk" d="M 122 31 H 296"></path>
      <g class="mg-ticks">
        <path class="mg-tick" style="--td: 1.1s" d="M 150 25 V 37"></path>
        <path class="mg-tick" style="--td: 1.2s" d="M 182 25 V 37"></path>
        <path class="mg-tick" style="--td: 1.3s" d="M 214 25 V 37"></path>
        <path class="mg-tick" style="--td: 1.4s" d="M 246 25 V 37"></path>
        <path class="mg-tick" style="--td: 1.5s" d="M 278 25 V 37"></path>
      </g>
    </svg>

    <!-- 設計 → 実装 → 定着 の流れ -->
    <div class="impl__phases reveal" style="--reveal-delay: 0.3s" aria-hidden="true">
      <span class="impl__phase">設計</span>
      <span class="impl__phase-line"></span>
      <span class="impl__phase">実装</span>
      <span class="impl__phase-line"></span>
      <span class="impl__phase">定着</span>
    </div>

    <!-- チェックリストの紙面 -->
    <div class="impl__sheet reveal" style="--reveal-delay: 0.15s">
      <ol class="impl__list">
        {
          items.map((item, i) => (
            <li class="impl__row" style={`--i: ${i}`}>
              <span class="impl__phase-tag">{item.phase}</span>
              <span class="impl__check" aria-hidden="true" />
              <div class="impl__text">
                <h3 class="impl__title">
                  <span class="impl__num">{item.num}</span>
                  {item.title}
                </h3>
                <p class="impl__body">{item.body}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>

<style>
  .impl {
    background: var(--c-white);
  }

  .impl__heading {
    margin-top: 36px;
  }

  .impl__lead {
    margin-top: 32px;
  }

  /* --- 合流する道筋 --- */
  .impl__merge {
    display: block;
    width: 280px;
    height: 60px;
    margin-top: 72px;
  }

  .mg {
    stroke: rgba(255, 90, 31, 0.85);
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-dasharray: 190;
    stroke-dashoffset: 190;
    transition: stroke-dashoffset 0.9s cubic-bezier(0.22, 1, 0.36, 1)
      var(--md, 0.2s);
  }

  .mg--trunk {
    transition-delay: 0.8s;
  }

  .mg-tick {
    stroke: rgba(17, 17, 17, 0.45);
    stroke-width: 1.2;
    stroke-dasharray: 14;
    stroke-dashoffset: 14;
    transition: stroke-dashoffset 0.4s ease var(--td, 1.1s);
  }

  .impl__merge.is-visible :is(.mg, .mg-tick) {
    stroke-dashoffset: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .mg,
    .mg-tick {
      transition: none;
      stroke-dashoffset: 0;
    }
  }

  @media (max-width: 720px) {
    .impl__merge {
      display: none;
    }
  }

  /* --- フェーズの流れ --- */
  .impl__phases {
    margin-top: 40px;
    display: flex;
    align-items: center;
    gap: 20px;
    max-width: 480px;
  }

  .impl__phase {
    font-size: 13px;
    letter-spacing: 0.2em;
    color: var(--c-sub);
    border: 1px solid var(--c-hairline);
    background: var(--c-white);
    border-radius: 999px;
    padding: 6px 20px;
    white-space: nowrap;
  }

  .impl__phase-line {
    flex: 1;
    height: 1px;
    background: var(--c-hairline);
  }

  /* --- チェックリスト紙面 --- */
  .impl__sheet {
    margin-top: 28px;
    background: var(--c-white);
    border: 1px solid var(--c-hairline);
    border-radius: var(--radius);
    box-shadow: var(--shadow-paper);
    padding: clamp(12px, 2vw, 24px) clamp(24px, 4vw, 56px);
    max-width: 920px;
  }

  .impl__list {
    list-style: none;
  }

  .impl__row {
    display: grid;
    grid-template-columns: 72px 30px 1fr;
    gap: clamp(16px, 2.5vw, 32px);
    align-items: start;
    padding-block: clamp(24px, 3.5vw, 36px);
    border-top: 1px solid var(--c-hairline);
  }

  .impl__row:first-child {
    border-top: 0;
  }

  .impl__phase-tag {
    font-size: 12px;
    letter-spacing: 0.16em;
    color: var(--c-blue);
    padding-top: 4px;
  }

  /* チェックボックス:表示時に緑のチェックが入る */
  .impl__check {
    position: relative;
    width: 20px;
    height: 20px;
    margin-top: 3px;
    border: 1px solid var(--c-hairline);
    border-radius: 5px;
    background: var(--c-base);
  }

  .impl__check::after {
    content: "";
    position: absolute;
    left: 4px;
    top: 5px;
    width: 10px;
    height: 5px;
    border-left: 2px solid var(--c-green);
    border-bottom: 2px solid var(--c-green);
    transform: rotate(-45deg) scale(0);
    transform-origin: center;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: calc(var(--i) * 0.14s + 0.6s);
  }

  .impl__sheet.is-visible .impl__check::after {
    transform: rotate(-45deg) scale(1);
  }

  .impl__title {
    font-size: clamp(16px, 1.9vw, 19px);
    font-weight: 500;
    letter-spacing: 0.1em;
    display: flex;
    align-items: baseline;
    gap: 14px;
  }

  .impl__num {
    font-family: var(--font-en);
    font-weight: 300;
    font-size: 12px;
    letter-spacing: 0.18em;
    color: var(--c-sub);
  }

  .impl__body {
    margin-top: 10px;
    font-size: 13.5px;
    line-height: 2.2;
    color: var(--c-sub);
  }

  @media (max-width: 720px) {
    .impl__row {
      grid-template-columns: 26px 1fr;
    }

    .impl__phase-tag {
      grid-column: 1 / 3;
      padding-top: 0;
    }

    .impl__phase-tag:empty {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .impl__check::after {
      transform: rotate(-45deg) scale(1);
      transition: none;
    }
  }
</style>
