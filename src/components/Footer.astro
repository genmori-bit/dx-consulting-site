---
import { SITE } from "../config";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <p class="footer__logo">
        <span class="footer__logo-name">ミチカク</span>
        <svg
          class="footer__logo-line"
          viewBox="0 0 132 12"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M2 7 C 24 3, 44 10, 66 7 C 88 4, 106 8, 118 6"
            stroke="#2E6E5A"
            stroke-width="2.4"
            stroke-linecap="round"></path>
          <circle cx="126" cy="5.5" r="4" fill="#E06A3F"></circle>
        </svg>
      </p>
      <p class="footer__tagline">{SITE.tagline}</p>
      <p class="footer__tagline-en">Workflows, Re-designed.</p>
    </div>
    <nav class="footer__nav" aria-label="フッターナビゲーション">
      <a href={`${base}services/`}>支援内容</a>
      <a href={`${base}local-business/`}>地域企業のDX</a>
      <a href={`${base}#process`}>支援の流れ</a>
      <a href={`${base}company/`}>会社概要</a>
      <a href={`${base}#contact`}>お問い合わせ</a>
      <a href={`${base}privacy/`}>プライバシーポリシー</a>
    </nav>
  </div>
  <div class="container footer__bottom">
    <small>© {year} {SITE.brandJa}</small>
    <a href="#top" class="footer__top">Back to top ↑</a>
  </div>
</footer>

<style>
  .footer {
    background: var(--c-black);
    border-top: 1px solid var(--line);
    padding-top: 72px;
  }

  .footer__inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 40px;
    flex-wrap: wrap;
  }

  .footer__logo {
    display: inline-flex;
    flex-direction: column;
    gap: 6px;
  }

  .footer__logo-name {
    font-weight: 700;
    font-size: 22px;
    letter-spacing: 0.18em;
    line-height: 1;
  }

  .footer__logo-line {
    width: 116px;
    height: 11px;
    display: block;
  }

  .footer__tagline {
    margin-top: 14px;
    font-size: 12.5px;
    letter-spacing: 0.2em;
    color: var(--c-sub);
  }

  .footer__tagline-en {
    margin-top: 6px;
    font-family: var(--font-en);
    font-size: 10.5px;
    font-weight: 400;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--c-hairline);
  }

  .footer__nav {
    display: flex;
    gap: 28px;
    flex-wrap: wrap;
  }

  .footer__nav a {
    font-size: 12.5px;
    letter-spacing: 0.1em;
    color: var(--c-muted);
    transition: color 0.3s ease;
  }

  .footer__nav a:hover {
    color: var(--c-ink);
  }

  .footer__bottom {
    margin-top: 64px;
    padding-block: 28px;
    border-top: 1px solid var(--line);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
  }

  .footer__bottom small {
    font-size: 11.5px;
    letter-spacing: 0.08em;
    color: var(--c-muted);
  }

  .footer__top {
    font-family: var(--font-en);
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--c-muted);
    transition: color 0.3s ease;
  }

  .footer__top:hover {
    color: var(--c-gold);
  }
</style>
