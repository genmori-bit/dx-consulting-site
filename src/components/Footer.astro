---
import { SITE } from "../config";

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <p class="footer__logo">{SITE.brandEn}</p>
      <p class="footer__tagline">Business, Re-designed.</p>
    </div>
    <nav class="footer__nav" aria-label="フッターナビゲーション">
      <a href="#issues">課題</a>
      <a href="#philosophy">考え方</a>
      <a href="#services">サービス</a>
      <a href="#strengths">強み</a>
      <a href="#process">支援の流れ</a>
      <a href="#contact">お問い合わせ</a>
    </nav>
  </div>
  <div class="container footer__bottom">
    <small>© {year} {SITE.brandJa}</small>
    <a href="#top" class="footer__top">Back to top ↑</a>
  </div>
</footer>

<style>
  .footer {
    background: var(--c-black);
    border-top: 1px solid var(--line);
    padding-top: 72px;
  }

  .footer__inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 40px;
    flex-wrap: wrap;
  }

  .footer__logo {
    font-family: var(--font-en);
    font-size: 22px;
    font-weight: 300;
    letter-spacing: 0.06em;
  }

  .footer__tagline {
    margin-top: 10px;
    font-family: var(--font-en);
    font-size: 12px;
    font-weight: 300;
    letter-spacing: 0.2em;
    color: var(--c-gold);
  }

  .footer__nav {
    display: flex;
    gap: 28px;
    flex-wrap: wrap;
  }

  .footer__nav a {
    font-size: 12.5px;
    letter-spacing: 0.1em;
    color: var(--c-muted);
    transition: color 0.3s ease;
  }

  .footer__nav a:hover {
    color: var(--c-ink);
  }

  .footer__bottom {
    margin-top: 64px;
    padding-block: 28px;
    border-top: 1px solid var(--line);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
  }

  .footer__bottom small {
    font-size: 11.5px;
    letter-spacing: 0.08em;
    color: var(--c-muted);
  }

  .footer__top {
    font-family: var(--font-en);
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--c-muted);
    transition: color 0.3s ease;
  }

  .footer__top:hover {
    color: var(--c-gold);
  }
</style>
