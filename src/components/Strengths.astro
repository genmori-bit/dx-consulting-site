---
const strengths = [
  {
    num: "01",
    title: "経営と現場をつなぐ",
    body: "経営の意思決定と現場のオペレーション、両方の言葉を理解し、翻訳しながらプロジェクトを前に進めます。",
  },
  {
    num: "02",
    title: "ツールありきではなく、課題起点",
    body: "特定ツールの販売を目的としないため、課題に対して最適な手段を中立な立場で選択できます。",
  },
  {
    num: "03",
    title: "導入後の定着まで伴走",
    body: "運用設計、トレーニング、活用データの振り返りまで。「使われている状態」をゴールに支援します。",
  },
  {
    num: "04",
    title: "AI・営業・業務改善を横断",
    body: "領域ごとに分断されがちなDXを、ひとつの設計思想で横断的に支援。部分最適で終わらせません。",
  },
];
---

<section class="section strengths" id="strengths">
  <div class="container">
    <p class="en-label reveal">Strengths</p>
    <h2 class="heading-ja strengths__heading reveal" style="--reveal-delay: 0.1s">
      私たちが選ばれる理由
    </h2>

    <ol class="strengths__list">
      {
        strengths.map((item) => (
          <li class="strengths__row reveal">
            <span class="strengths__num en-display">{item.num}</span>
            <h3 class="strengths__title">{item.title}</h3>
            <p class="strengths__body">{item.body}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .strengths {
    background: var(--c-charcoal);
    border-block: 1px solid var(--line);
  }

  .strengths__heading {
    margin-top: 36px;
  }

  .strengths__list {
    margin-top: 88px;
    list-style: none;
  }

  .strengths__row {
    display: grid;
    grid-template-columns: 140px 1fr 1.2fr;
    gap: clamp(20px, 3vw, 48px);
    align-items: baseline;
    padding-block: clamp(42px, 5vw, 64px);
    border-top: 1px solid var(--line);
  }

  .strengths__row:last-child {
    border-bottom: 1px solid var(--line);
  }

  .strengths__num {
    font-size: clamp(40px, 5vw, 64px);
    font-weight: 200;
    color: transparent;
    -webkit-text-stroke: 1px rgba(200, 169, 106, 0.35);
  }

  .strengths__title {
    font-size: clamp(17px, 2vw, 21px);
    font-weight: 400;
    letter-spacing: 0.1em;
  }

  .strengths__body {
    font-size: 14px;
    color: var(--c-muted);
  }

  @media (max-width: 840px) {
    .strengths__row {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .strengths__num {
      font-size: 36px;
    }
  }
</style>
