---
/**
 * Career(トップページ・コンパクト版)
 * 左に見出しとメインコピー、右に本文。詳細は /company/#career へ。
 * 本文テキストは src/data/career.ts で一元管理。
 */
import { SITE } from "../config";
import { CAREER } from "../data/career";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<section class="section founder" id="founder">
  <div class="container">
    <p class="en-label reveal">06 / Career</p>

    <div class="founder__grid">
      <!-- 左:見出し・メインコピー・名前 -->
      <div class="founder__head">
        <h2 class="founder__title en-display reveal" style="--reveal-delay: 0.1s">
          Career
        </h2>
        <p class="founder__copy reveal" style="--reveal-delay: 0.2s">
          B2B SaaSの、<em>つくる</em>・<em>届ける</em>・<em>使われ続ける</em>を。
        </p>
        <p class="founder__name reveal" style="--reveal-delay: 0.3s">
          <span class="founder__role">代表</span>
          {SITE.representative}
          <span class="founder__name-en">Genki Mouri</span>
        </p>
      </div>

      <!-- 右:本文 -->
      <div class="founder__body">
        <p class="reveal" style="--reveal-delay: 0.25s">{CAREER.lead}</p>
        {
          CAREER.topParagraphs.map((paragraph, i) => (
            <p class="reveal" style={`--reveal-delay: ${0.4 + i * 0.15}s`}>
              {paragraph}
            </p>
          ))
        }

        <p class="founder__emphasis reveal" style="--reveal-delay: 0.75s">
          {CAREER.emphasis}
        </p>

        <a
          href={`${base}company/#career`}
          class="founder__more cta-flow reveal"
          style="--reveal-delay: 0.85s"
          >詳しい経歴を見る<span class="cta-arrow" aria-hidden="true">→</span></a
        >

        <p class="founder__note reveal" style="--reveal-delay: 0.9s">
          {CAREER.disclaimer}
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .founder {
    background: var(--c-base);
    border-top: 1px solid var(--line);
  }

  .founder__grid {
    margin-top: 72px;
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(48px, 6vw, 112px);
    align-items: start;
  }

  /* --- 左:見出し --- */
  .founder__title {
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 200;
  }

  .founder__copy {
    margin-top: 28px;
    font-size: clamp(17px, 2vw, 21px);
    font-weight: 500;
    letter-spacing: 0.1em;
    line-height: 2;
    max-width: 400px;
  }

  /* 「つくる」「届ける」「使われ続ける」の強調 */
  .founder__copy em {
    font-style: normal;
    background-image: linear-gradient(
      rgba(224, 103, 60, 0.7),
      rgba(224, 103, 60, 0.7)
    );
    background-repeat: no-repeat;
    background-size: 100% 2px;
    background-position: 0 100%;
    padding-bottom: 3px;
  }

  .founder__name {
    margin-top: 44px;
    display: flex;
    align-items: baseline;
    gap: 14px;
    flex-wrap: wrap;
    font-size: 18px;
    font-weight: 500;
    letter-spacing: 0.14em;
  }

  .founder__role {
    font-size: 11.5px;
    letter-spacing: 0.2em;
    color: var(--c-sub);
  }

  .founder__name-en {
    font-family: var(--font-en);
    font-weight: 300;
    font-size: 12px;
    letter-spacing: 0.12em;
    color: var(--c-sub);
  }

  /* --- 右:本文 --- */
  .founder__body {
    max-width: 560px;
  }

  .founder__body > p {
    font-size: 14px;
    line-height: 2.4;
    color: var(--c-sub);
  }

  .founder__body > p + p {
    margin-top: 1.7em;
  }

  /* 強調文:本文と距離を取り、道筋のオレンジ線を添える */
  .founder__emphasis {
    margin-top: 3.2em !important;
    padding-left: 22px;
    border-left: 1.5px solid rgba(224, 103, 60, 0.7);
    font-size: 14.5px !important;
    color: var(--c-text) !important;
    letter-spacing: 0.06em;
  }

  .founder__more {
    display: inline-block;
    margin-top: 44px;
    font-size: 13.5px;
    letter-spacing: 0.14em;
    color: var(--c-text);
    border-bottom: 1px solid var(--c-hairline);
    padding-bottom: 5px;
    transition: border-color 0.3s ease;
  }

  .founder__more:hover {
    border-color: transparent;
  }

  .founder__more.cta-flow::after {
    background: #e0673c;
  }

  /* 所属企業に関する注記 */
  .founder__note {
    margin-top: 40px !important;
    font-size: 10.5px !important;
    line-height: 2 !important;
    letter-spacing: 0.06em;
    color: var(--c-sub) !important;
    opacity: 0.75;
  }

  @media (max-width: 840px) {
    .founder__grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .founder__copy {
      max-width: none;
    }
  }
</style>
