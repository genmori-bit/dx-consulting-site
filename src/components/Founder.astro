---
/**
 * Career(トップページ・コンパクト版)
 * 左に見出しとメインコピー、右に本文。詳細は /company/#career へ。
 * 本文テキストは src/data/career.ts で一元管理。
 */
import { SITE } from "../config";
import { CAREER } from "../data/career";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<section class="section founder" id="founder">
  <div class="container">
    <p class="en-label reveal">06 / Career</p>

    <div class="founder__grid">
      <!-- 左:見出し・メインコピー・名前 -->
      <div class="founder__head">
        <h2 class="founder__title en-display reveal" style="--reveal-delay: 0.1s">
          Career
        </h2>
        <p class="founder__copy reveal" style="--reveal-delay: 0.2s">
          B2B SaaSの、<em>つくる</em>・<em>届ける</em>・<em>使われ続ける</em>を。
        </p>
        <p class="founder__name reveal" style="--reveal-delay: 0.3s">
          <span class="founder__role">代表</span>
          {SITE.representative}
          <span class="founder__name-en">Genki Mouri</span>
        </p>
      </div>

      <!-- 右:本文 -->
      <div class="founder__body">
        <p class="reveal" style="--reveal-delay: 0.25s">{CAREER.lead}</p>
        {
          CAREER.topParagraphs.map((paragraph, i) => (
            <p class="reveal" style={`--reveal-delay: ${0.4 + i * 0.15}s`}>
              {paragraph}
            </p>
          ))
        }

        <p class="founder__emphasis reveal" style="--reveal-delay: 0.75s">
          {CAREER.emphasis}
        </p>

        <a
          href={`${base}company/#career`}
          class="founder__more cta-flow reveal"
          style="--reveal-delay: 0.85s"
          >詳しい経歴を見る<span class="cta-arrow" aria-hidden="true">→</span></a
        >

        <p class="founder__note reveal" style="--reveal-delay: 0.9s">
          {CAREER.disclaimer}
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  /* 人物と経歴のセクション:色ではなく余白・文字・一本の線で見せる */
  .founder {
    background: var(--c-white);
    border-top: 1px solid var(--c-hairline);
  }

  .founder__grid {
    margin-top: 72px;
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(48px, 6vw, 112px);
    align-items: start;
  }

  /* --- 左:見出し --- */
  .founder__title {
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 200;
  }

  .founder__copy {
    margin-top: 28px;
    font-size: clamp(17px, 2vw, 21px);
    font-weight: 500;
    letter-spacing: 0.1em;
    line-height: 2;
    max-width: 400px;
  }

  /*
   * 「つくる」「届ける」「使われ続ける」:
   * 常時下線は付けず、表示時に順番にオレンジへ灯って黒に戻る。
   * 最後はコピー下の一本の細いオレンジ線だけが残り、静止する。
   */
  .founder__copy em {
    font-style: normal;
    color: var(--c-text);
  }

  .founder__copy.is-visible em {
    animation: word-flash 0.9s ease both;
  }

  .founder__copy.is-visible em:nth-of-type(1) { animation-delay: 0.9s; }
  .founder__copy.is-visible em:nth-of-type(2) { animation-delay: 1.3s; }
  .founder__copy.is-visible em:nth-of-type(3) { animation-delay: 1.7s; }

  @keyframes word-flash {
    0%, 100% { color: var(--c-text); }
    40% { color: var(--c-primary); }
  }

  /* 残る一本の細いオレンジ線(左から右へ伸びて静止) */
  .founder__copy::after {
    content: "";
    display: block;
    width: 76px;
    height: 2px;
    margin-top: 20px;
    background: var(--c-primary);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.4s;
  }

  .founder__copy.is-visible::after {
    transform: scaleX(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .founder__copy.is-visible em {
      animation: none;
    }
    .founder__copy::after {
      transition: none;
      transform: scaleX(1);
    }
  }

  .founder__name {
    margin-top: 44px;
    display: flex;
    align-items: baseline;
    gap: 14px;
    flex-wrap: wrap;
    font-size: 18px;
    font-weight: 500;
    letter-spacing: 0.14em;
  }

  .founder__role {
    font-size: 11.5px;
    letter-spacing: 0.2em;
    color: var(--c-sub);
  }

  .founder__name-en {
    font-family: var(--font-en);
    font-weight: 300;
    font-size: 12px;
    letter-spacing: 0.12em;
    color: var(--c-sub);
  }

  /* --- 右:本文 --- */
  .founder__body {
    max-width: 560px;
  }

  .founder__body > p {
    font-size: 14px;
    line-height: 2.4;
    color: var(--c-body);
  }

  .founder__body > p + p {
    margin-top: 1.7em;
  }

  /* 強調文:本文と距離を取り、道筋のオレンジ線を添える */
  .founder__emphasis {
    margin-top: 3.2em !important;
    padding-left: 22px;
    border-left: 2px solid var(--c-primary);
    font-size: 14.5px !important;
    color: var(--c-text) !important;
    letter-spacing: 0.06em;
  }

  .founder__more {
    display: inline-block;
    margin-top: 44px;
    font-size: 13.5px;
    letter-spacing: 0.14em;
    color: var(--c-text);
    border-bottom: 1px solid var(--c-hairline);
    padding-bottom: 5px;
    transition: border-color 0.3s ease;
  }

  .founder__more:hover {
    border-color: transparent;
  }

  .founder__more.cta-flow::after {
    background: var(--c-primary);
  }

  /* 所属企業に関する注記 */
  .founder__note {
    margin-top: 40px !important;
    font-size: 10.5px !important;
    line-height: 2 !important;
    letter-spacing: 0.06em;
    color: var(--c-sub) !important;
    opacity: 0.75;
  }

  @media (max-width: 840px) {
    .founder__grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .founder__copy {
      max-width: none;
    }
  }
</style>
