---
/**
 * 地域企業向けセクション。
 * サイト内で最初の濃色(深緑)面。白基調の流れに強いコントラストをつくる。
 */
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const points = [
  "IT担当者がいなくても、進められます",
  "1つの業務、1つの会議からでも始められます",
  "今お使いのExcelやツールを活かして設計します",
];
---

<section class="section local" id="local-business">
  <div class="container">
    <p class="en-label local__label reveal">03 / For Local Business</p>

    <h2 class="heading-ja local__heading reveal" style="--reveal-delay: 0.1s">
      地域企業に、ちょうどいいDXを。
    </h2>

    <div class="local__cols">
      <div class="local__body reveal" style="--reveal-delay: 0.2s">
        <p>
          デジタル化は、大きなシステムを入れることだけではありません。
          人手が限られ、業務が属人化しやすい会社にこそ、
          仕事の流れを整え、少ない人数でも回る仕組みが必要です。
        </p>
        <p>
          大きなシステムを入れる前に、
          まずは、今の仕事の流れを一緒に見直すところから。
        </p>
        <p>
          ミチカクは、営業・管理部門・経営判断の流れを整理し、
          今ある業務に合ったデジタル活用を設計します。
        </p>
        <p>
          無理に大きく変えるのではなく、
          現場で使われ、会社に残る仕組みを一つずつつくっていきます。
        </p>
      </div>

      <div class="local__aside">
        <ul class="local__points">
          {
            points.map((point, i) => (
              <li class="reveal" style={`--reveal-delay: ${0.3 + i * 0.12}s`}>
                {point}
              </li>
            ))
          }
        </ul>

        <div class="local__actions reveal" style="--reveal-delay: 0.6s">
          <a href={`${base}#contact`} class="local__cta cta-flow"
            >地域企業のDXを相談する<span class="cta-arrow" aria-hidden="true">→</span></a
          >
          <a href={`${base}local-business/`} class="local__more">詳しく見る</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* 深緑の濃色面。文字はほぼ白で十分なコントラストを確保 */
  .local {
    background: var(--c-secondary);
    color: var(--c-base);
  }

  .local__label {
    color: rgba(248, 248, 246, 0.75);
  }

  .local__label::before {
    background: rgba(248, 248, 246, 0.45);
  }

  .local__heading {
    margin-top: 36px;
    color: #fff;
  }

  .local__cols {
    margin-top: 72px;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: clamp(48px, 6vw, 112px);
    align-items: start;
  }

  .local__body p {
    font-size: 15px;
    line-height: 2.4;
    color: rgba(248, 248, 246, 0.88);
  }

  .local__body p + p {
    margin-top: 1.8em;
  }

  /* --- 安心材料:罫線とチェックで見せる(付箋は廃止) --- */
  .local__points {
    list-style: none;
  }

  .local__points li {
    position: relative;
    padding: 16px 0 16px 28px;
    border-top: 1px solid rgba(248, 248, 246, 0.22);
    font-size: 14px;
    letter-spacing: 0.08em;
    color: #fff;
  }

  .local__points li:last-child {
    border-bottom: 1px solid rgba(248, 248, 246, 0.22);
  }

  .local__points li::before {
    content: "";
    position: absolute;
    left: 2px;
    top: 26px;
    width: 9px;
    height: 5px;
    border-left: 2px solid var(--c-primary);
    border-bottom: 2px solid var(--c-primary);
    transform: rotate(-45deg);
  }

  .local__actions {
    margin-top: 44px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  /* Primary CTA:焼きオレンジ */
  .local__cta {
    display: block;
    text-align: center;
    padding: 17px 24px;
    background: var(--c-primary);
    border: 1px solid var(--c-primary);
    border-radius: 10px;
    color: #fff;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.14em;
    transition: background-color 0.35s ease, border-color 0.35s ease,
      translate 0.35s ease;
  }

  .local__cta:hover {
    background: var(--c-primary-dark);
    border-color: var(--c-primary-dark);
    translate: 0 -2px;
  }

  .local__more {
    align-self: center;
    font-size: 13px;
    letter-spacing: 0.14em;
    color: rgba(248, 248, 246, 0.8);
    border-bottom: 1px solid rgba(248, 248, 246, 0.35);
    padding-bottom: 4px;
    transition: color 0.3s ease, border-color 0.3s ease;
  }

  .local__more:hover {
    color: #fff;
    border-color: #fff;
  }

  @media (max-width: 840px) {
    .local__cols {
      grid-template-columns: 1fr;
    }
  }
</style>
