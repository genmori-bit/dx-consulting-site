---
const issues = [
  {
    num: "01",
    en: "Process",
    ja: "業務の流れが、人に依存している。",
  },
  {
    num: "02",
    en: "Data",
    ja: "判断に必要な情報が、集まらない。",
  },
  {
    num: "03",
    en: "Systems",
    ja: "システムが、仕事の流れにつながっていない。",
  },
  {
    num: "04",
    en: "Adoption",
    ja: "使われ続ける状態になっていない。",
  },
];
---

<section class="section issues" id="issues">
  <div class="container">
    <p class="en-label reveal">01 / Issues</p>
    <h2 class="heading-ja issues__heading reveal" style="--reveal-delay: 0.1s">
      止まっているのは、<br />だいたい同じ場所です。
    </h2>
    <p class="lead issues__lead reveal" style="--reveal-delay: 0.2s">
      事業や規模が違っても、仕事が詰まる場所は似ています。
      私たちは、会社の中で起きていることを4つの層に分けて見ています。
    </p>

    <!-- 一本の業務ラインの上に、詰まりが順に現れる -->
    <div class="issues__flow reveal">
      <span class="issues__line" aria-hidden="true"></span>
      <ol class="issues__items">
        {
          issues.map((item, i) => (
            <li class="issues__item" style={`--i: ${i}`}>
              <span class="issues__node" aria-hidden="true" />
              <span class="issues__num">{item.num}</span>
              <span class="issues__en">{item.en}</span>
              <p class="issues__ja">{item.ja}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>

<style>
  .issues {
    background: var(--c-charcoal);
    border-block: 1px solid var(--line);
  }

  .issues__heading {
    margin-top: 36px;
  }

  .issues__lead {
    margin-top: 32px;
  }

  /* --- 業務ライン --- */
  .issues__flow {
    position: relative;
    margin-top: 128px;
  }

  .issues__line {
    position: absolute;
    top: 3px;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--line);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 1.6s cubic-bezier(0.16, 1, 0.3, 1) 0.2s;
  }

  .issues__flow.is-visible .issues__line {
    transform: scaleX(1);
  }

  .issues__items {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(24px, 3vw, 48px);
  }

  /* ライン描画に合わせて、左から順番に現れる */
  .issues__item {
    position: relative;
    padding-top: 40px;
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.9s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: calc(var(--i) * 0.18s + 0.45s);
  }

  .issues__flow.is-visible .issues__item {
    opacity: 1;
    transform: none;
  }

  /* 詰まりポイント(オレンジ) */
  .issues__node {
    position: absolute;
    top: 0;
    left: 0;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 1px solid var(--c-orange);
    background: rgba(240, 138, 75, 0.25);
  }

  .issues__num {
    font-family: var(--font-en);
    font-weight: 300;
    font-size: 13px;
    letter-spacing: 0.2em;
    color: var(--c-orange);
  }

  .issues__en {
    display: block;
    margin-top: 12px;
    font-family: var(--font-en);
    font-weight: 300;
    font-size: clamp(22px, 2.4vw, 32px);
  }

  .issues__ja {
    margin-top: 16px;
    font-size: 14px;
    line-height: 2.2;
    letter-spacing: 0.08em;
    color: var(--c-ink);
  }

  /* スマホ:縦に流れるライン */
  @media (max-width: 840px) {
    .issues__line {
      left: 3px;
      right: auto;
      top: 0;
      bottom: 0;
      width: 1px;
      height: auto;
      transform: scaleY(0);
      transform-origin: top;
    }

    .issues__flow.is-visible .issues__line {
      transform: scaleY(1);
    }

    .issues__items {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .issues__item {
      padding: 0 0 48px 36px;
    }

    .issues__node {
      top: 6px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .issues__line {
      transform: none;
      transition: none;
    }
    .issues__item {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>
