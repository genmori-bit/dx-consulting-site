---
const steps = [
  {
    num: "01",
    en: "Audit",
    body: "業務、データ、ツール、人の流れを棚卸しする。",
  },
  {
    num: "02",
    en: "Blueprint",
    body: "残す業務、なくす業務、自動化する業務を切り分ける。",
  },
  {
    num: "03",
    en: "Build",
    body: "CRM/SFA、SaaS、AI、自動化、ダッシュボードを必要な範囲で実装する。",
  },
  {
    num: "04",
    en: "Run",
    body: "運用ルール、トレーニング、改善のリズムを整える。",
  },
];
---

<section class="section process" id="process">
  <div class="container">
    <p class="en-label reveal">04 / Process</p>
    <h2 class="heading-ja process__heading reveal" style="--reveal-delay: 0.1s">
      支援の流れ
    </h2>
    <p class="lead process__lead reveal" style="--reveal-delay: 0.2s">
      いきなり作りはじめません。診断から運用まで、4つの段階で進めます。
    </p>

    <ol class="process__steps">
      {
        steps.map((step, i) => (
          <li class="process__step reveal" style={`--reveal-delay: ${i * 0.12}s`}>
            <span class="process__num">{step.num}</span>
            <span class="process__en en-display">{step.en}</span>
            <p class="process__body">{step.body}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .process {
    background: var(--c-black);
  }

  .process__heading {
    margin-top: 36px;
  }

  .process__lead {
    margin-top: 32px;
  }

  .process__steps {
    margin-top: 112px;
    list-style: none;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(32px, 4vw, 56px);
  }

  .process__step {
    border-top: 1px solid var(--line);
    padding-top: 36px;
  }

  .process__num {
    display: block;
    font-family: var(--font-en);
    font-weight: 200;
    font-size: 13px;
    letter-spacing: 0.2em;
    color: var(--c-gold);
  }

  .process__en {
    display: block;
    margin-top: 14px;
    font-size: clamp(22px, 2.2vw, 30px);
    font-weight: 300;
  }

  .process__body {
    margin-top: 20px;
    font-size: 13.5px;
    line-height: 2.3;
    color: var(--c-muted);
  }

  @media (max-width: 840px) {
    .process__steps {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .process__step {
      padding-block: 44px 52px;
    }
  }
</style>
