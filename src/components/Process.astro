---
interface Props {
  label?: string;
}

const { label = "05 / Process" } = Astro.props;

const steps = [
  {
    num: "01",
    en: "Audit",
    body: "現状の業務、データ、システム、人の流れを棚卸しする。",
  },
  {
    num: "02",
    en: "Strategy",
    body: "どこから変えるか、何をやらないか、優先順位を決める。",
  },
  {
    num: "03",
    en: "Design",
    body: "業務フロー、データ項目、システム構成、運用ルールを設計する。",
  },
  {
    num: "04",
    en: "Build",
    body: "必要な業務システム、自動化、AI活用、レポート環境を実装する。",
  },
  {
    num: "05",
    en: "Enable",
    body: "現場が使い続けられるよう、教育、ルール、改善のリズムを整える。",
  },
];
---

<section class="section process" id="process">
  <div class="container">
    <p class="en-label reveal">{label}</p>
    <h2 class="heading-ja process__heading reveal" style="--reveal-delay: 0.1s">
      小さく始めて、使われるまで。
    </h2>
    <p class="lead process__lead reveal" style="--reveal-delay: 0.2s">
      いきなり作りはじめません。現状の棚卸しから運用の定着まで、5つの段階で進めます。
    </p>

    <!-- スクロールに合わせて細いラインが伸びるタイムライン -->
    <div class="process__timeline" data-process-timeline>
      <span class="process__track" aria-hidden="true">
        <span class="process__fill" data-process-fill></span>
      </span>

      <ol class="process__steps">
        {
          steps.map((step, i) => (
            <li class="process__step reveal" style={`--reveal-delay: ${i * 0.08}s`}>
              <span class="process__marker" aria-hidden="true" />
              <span class="process__num">{step.num}</span>
              <span class="process__en en-display">{step.en}</span>
              <p class="process__body">{step.body}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>

<script>
  // タイムラインのラインを、スクロール位置に合わせて静かに伸ばす
  const fills = [...document.querySelectorAll<HTMLElement>("[data-process-fill]")];
  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (fills.length) {
    if (reduced) {
      fills.forEach((fill) => (fill.style.transform = "scaleY(1)"));
    } else {
      let ticking = false;
      const update = () => {
        for (const fill of fills) {
          const timeline = fill.closest("[data-process-timeline]");
          if (!timeline) continue;
          const rect = timeline.getBoundingClientRect();
          const progress = Math.min(
            1,
            Math.max(0, (window.innerHeight * 0.8 - rect.top) / rect.height)
          );
          fill.style.transform = `scaleY(${progress})`;
        }
        ticking = false;
      };
      window.addEventListener(
        "scroll",
        () => {
          if (!ticking) {
            ticking = true;
            requestAnimationFrame(update);
          }
        },
        { passive: true }
      );
      update();
    }
  }
</script>

<style>
  .process {
    background: var(--c-base);
    border-block: 1px solid var(--line);
  }

  .process__heading {
    margin-top: 36px;
  }

  .process__lead {
    margin-top: 32px;
  }

  /* --- タイムライン --- */
  .process__timeline {
    position: relative;
    margin-top: 112px;
    max-width: 760px;
  }

  .process__track {
    position: absolute;
    left: 3px;
    top: 6px;
    bottom: 6px;
    width: 1px;
    background: var(--line);
  }

  /* スクロールに合わせて伸びる道筋(焼きオレンジ) */
  .process__fill {
    position: absolute;
    inset: 0;
    background: rgba(255, 90, 31, 0.8);
    transform: scaleY(0);
    transform-origin: top;
    will-change: transform;
  }

  .process__steps {
    list-style: none;
  }

  .process__step {
    position: relative;
    padding: 0 0 clamp(56px, 7vw, 88px) clamp(44px, 6vw, 72px);
  }

  .process__step:last-child {
    padding-bottom: 0;
  }

  .process__marker {
    position: absolute;
    left: 0;
    top: 5px;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    border: 1px solid var(--c-primary);
    background: var(--c-white);
  }

  /* 最終ステップ(Enable)は道筋の到達点=緑 */
  .process__step:last-child .process__marker {
    border-color: var(--c-secondary);
    background: var(--c-secondary);
  }

  .process__num {
    font-family: var(--font-en);
    font-weight: 200;
    font-size: 13px;
    letter-spacing: 0.2em;
    color: var(--c-gold);
  }

  .process__en {
    display: block;
    margin-top: 12px;
    font-size: clamp(24px, 2.6vw, 34px);
    font-weight: 300;
  }

  .process__body {
    margin-top: 16px;
    font-size: 14px;
    line-height: 2.3;
    color: var(--c-muted);
    max-width: 520px;
  }

  @media (max-width: 720px) {
    .process__step {
      padding-left: 36px;
    }
  }
</style>
