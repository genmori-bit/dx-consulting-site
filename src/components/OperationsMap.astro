---
/**
 * Operations Map — 営業・管理部門の業務が Data / AI / SaaS を介して
 * 経営の意思決定につながる構造を、罫線のみで描いた図。
 */
---

<svg
  class="opmap"
  viewBox="0 0 560 340"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="営業と管理部門の業務が、データ・AI・SaaSの層を介して経営の意思決定につながる構造図"
>
  <g class="om-box om-box--1">
    <rect x="30.5" y="18.5" width="210" height="64"></rect>
    <text class="om-en" x="135" y="48">SALES</text>
    <text class="om-ja" x="135" y="68">営業</text>
  </g>

  <g class="om-box om-box--2">
    <rect x="320.5" y="18.5" width="210" height="64"></rect>
    <text class="om-en" x="425" y="48">CORPORATE</text>
    <text class="om-ja" x="425" y="68">管理部門</text>
  </g>

  <path class="om-line om-line--1" d="M135.5 82.5 V170.5 H425.5 V82.5"></path>
  <path class="om-line om-line--2" d="M280.5 170.5 V236.5"></path>

  <g class="om-layer">
    <text class="om-tag" x="200" y="158">DATA</text>
    <text class="om-tag" x="280" y="158">AI</text>
    <text class="om-tag" x="360" y="158">SAAS</text>
    <rect class="om-node" x="197.5" y="167.5" width="6" height="6"></rect>
    <rect class="om-node" x="277.5" y="167.5" width="6" height="6"></rect>
    <rect class="om-node" x="357.5" y="167.5" width="6" height="6"></rect>
  </g>

  <g class="om-box om-box--3">
    <rect x="175.5" y="236.5" width="210" height="64"></rect>
    <text class="om-en" x="280" y="266">MANAGEMENT</text>
    <text class="om-ja" x="280" y="286">経営・意思決定</text>
  </g>
</svg>

<style>
  .opmap {
    width: 100%;
    height: auto;
    display: block;
  }

  .om-box rect {
    stroke: rgba(238, 236, 230, 0.3);
  }

  .om-en {
    fill: var(--c-ink);
    font-family: var(--font-en);
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.28em;
    text-anchor: middle;
  }

  .om-ja {
    fill: rgba(238, 236, 230, 0.48);
    font-family: var(--font-ja);
    font-size: 10px;
    letter-spacing: 0.24em;
    text-anchor: middle;
  }

  .om-line {
    stroke: rgba(238, 236, 230, 0.24);
  }

  .om-tag {
    fill: var(--c-gold);
    font-family: var(--font-en);
    font-size: 10px;
    letter-spacing: 0.26em;
    text-anchor: middle;
  }

  .om-node {
    stroke: var(--c-gold-dim);
  }

  /* 静かな描画:罫線が引かれ、層が現れる */
  .om-box,
  .om-layer {
    opacity: 0;
    animation: om-in 1.4s ease forwards;
  }

  .om-box--1 { animation-delay: 0.7s; }
  .om-box--2 { animation-delay: 0.9s; }
  .om-layer { animation-delay: 2.3s; }
  .om-box--3 { animation-delay: 2.9s; }

  .om-line--1 {
    stroke-dasharray: 470;
    stroke-dashoffset: 470;
    animation: om-draw 2.2s cubic-bezier(0.16, 1, 0.3, 1) 1.1s forwards;
  }

  .om-line--2 {
    stroke-dasharray: 70;
    stroke-dashoffset: 70;
    animation: om-draw 0.9s ease-out 2.7s forwards;
  }

  @keyframes om-in {
    to { opacity: 1; }
  }

  @keyframes om-draw {
    to { stroke-dashoffset: 0; }
  }

  /* スマホではSVGごと縮小されるため、文字サイズを上げて可読性を保つ */
  @media (max-width: 720px) {
    .om-en {
      font-size: 15px;
      letter-spacing: 0.22em;
    }
    .om-ja {
      font-size: 13px;
      letter-spacing: 0.18em;
    }
    .om-tag {
      font-size: 13px;
      letter-spacing: 0.2em;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .om-box,
    .om-layer {
      animation: none;
      opacity: 1;
    }
    .om-line {
      animation: none;
      stroke-dashoffset: 0;
    }
  }
</style>
