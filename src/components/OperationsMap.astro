---
/**
 * Operations Map — Front Office / Back Office の業務が Data Layer に集まり、
 * Management(経営判断)へ流れていく構造図。
 * 線は読み込み時に静かに引かれ、小さな光点がゆっくり流れる(SMIL、reduced-motion時は非表示)。
 */
---

<svg
  class="opmap"
  viewBox="0 0 560 400"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="フロントオフィスとバックオフィスの業務がデータ基盤に集まり、経営の意思決定へ流れる構造図"
>
  <g class="om-box om-box--1">
    <rect x="30.5" y="20.5" width="210" height="60"></rect>
    <text class="om-en" x="135" y="48">FRONT OFFICE</text>
    <text class="om-ja" x="135" y="68">顧客接点</text>
  </g>

  <g class="om-box om-box--2">
    <rect x="320.5" y="20.5" width="210" height="60"></rect>
    <text class="om-en" x="425" y="48">BACK OFFICE</text>
    <text class="om-ja" x="425" y="68">社内業務</text>
  </g>

  <!-- 業務 → データ基盤 -->
  <path class="om-line om-line--1" d="M135.5 80.5 V184.5"></path>
  <path class="om-line om-line--2" d="M425.5 80.5 V184.5"></path>

  <g class="om-box om-box--3">
    <rect x="95.5" y="184.5" width="370" height="64"></rect>
    <text class="om-en" x="280" y="212">DATA LAYER</text>
    <text class="om-tag" x="280" y="234">SYSTEM · AUTOMATION · AI</text>
  </g>

  <!-- データ基盤 → 経営判断 -->
  <path class="om-line om-line--3" d="M280.5 248.5 V316.5"></path>

  <g class="om-box om-box--4">
    <rect x="175.5" y="316.5" width="210" height="60"></rect>
    <text class="om-en" x="280" y="344">MANAGEMENT</text>
    <text class="om-ja" x="280" y="364">経営・意思決定</text>
  </g>

  <!-- 流れる光点(小さく、ゆっくり) -->
  <g class="om-dots" aria-hidden="true">
    <circle class="om-dot" r="2.4">
      <animateMotion dur="7s" begin="2s" repeatCount="indefinite" path="M135.5 80.5 L135.5 184.5"></animateMotion>
      <animate attributeName="opacity" values="0;0.75;0.75;0" keyTimes="0;0.15;0.8;1" dur="7s" begin="2s" repeatCount="indefinite"></animate>
    </circle>
    <circle class="om-dot" r="2.4">
      <animateMotion dur="7s" begin="5.4s" repeatCount="indefinite" path="M425.5 80.5 L425.5 184.5"></animateMotion>
      <animate attributeName="opacity" values="0;0.75;0.75;0" keyTimes="0;0.15;0.8;1" dur="7s" begin="5.4s" repeatCount="indefinite"></animate>
    </circle>
    <circle class="om-dot" r="2.4">
      <animateMotion dur="6s" begin="3.6s" repeatCount="indefinite" path="M280.5 248.5 L280.5 316.5"></animateMotion>
      <animate attributeName="opacity" values="0;0.75;0.75;0" keyTimes="0;0.2;0.8;1" dur="6s" begin="3.6s" repeatCount="indefinite"></animate>
    </circle>
  </g>
</svg>

<style>
  .opmap {
    width: 100%;
    height: auto;
    display: block;
  }

  .om-box rect {
    stroke: rgba(238, 236, 230, 0.28);
    transition: stroke 0.5s ease;
  }

  .om-en {
    fill: var(--c-ink);
    font-family: var(--font-en);
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.28em;
    text-anchor: middle;
  }

  .om-ja {
    fill: rgba(238, 236, 230, 0.48);
    font-family: var(--font-ja);
    font-size: 10px;
    letter-spacing: 0.24em;
    text-anchor: middle;
  }

  .om-tag {
    fill: var(--c-gold);
    font-family: var(--font-en);
    font-size: 9.5px;
    letter-spacing: 0.24em;
    text-anchor: middle;
    opacity: 0.85;
  }

  .om-line {
    stroke: rgba(238, 236, 230, 0.22);
    transition: stroke 0.5s ease;
  }

  .om-dot {
    fill: var(--c-gold);
    opacity: 0;
  }

  /* ホバー時だけ少し明るく */
  .opmap:hover .om-line {
    stroke: rgba(238, 236, 230, 0.42);
  }

  .opmap:hover .om-box rect {
    stroke: rgba(238, 236, 230, 0.44);
  }

  /* 静かな描画:箱が現れ、線が引かれる */
  .om-box {
    opacity: 0;
    animation: om-in 1.4s ease forwards;
  }

  .om-box--1 { animation-delay: 0.7s; }
  .om-box--2 { animation-delay: 0.9s; }
  .om-box--3 { animation-delay: 1.9s; }
  .om-box--4 { animation-delay: 2.7s; }

  .om-line--1,
  .om-line--2 {
    stroke-dasharray: 110;
    stroke-dashoffset: 110;
    animation: om-draw 1.4s cubic-bezier(0.16, 1, 0.3, 1) 1.2s forwards;
  }

  .om-line--2 {
    animation-delay: 1.4s;
  }

  .om-line--3 {
    stroke-dasharray: 72;
    stroke-dashoffset: 72;
    animation: om-draw 1s ease-out 2.4s forwards;
  }

  @keyframes om-in {
    to { opacity: 1; }
  }

  @keyframes om-draw {
    to { stroke-dashoffset: 0; }
  }

  /* スマホではSVGごと縮小されるため、文字サイズを上げて可読性を保つ */
  @media (max-width: 720px) {
    .om-en {
      font-size: 15px;
      letter-spacing: 0.22em;
    }
    .om-ja {
      font-size: 13px;
      letter-spacing: 0.18em;
    }
    .om-tag {
      font-size: 12px;
      letter-spacing: 0.18em;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .om-box {
      animation: none;
      opacity: 1;
    }
    .om-line {
      animation: none;
      stroke-dashoffset: 0;
    }
    .om-dots {
      display: none;
    }
  }
</style>
