---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import PageIntro from "../components/PageIntro.astro";
import Footer from "../components/Footer.astro";
import { SITE } from "../config";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const principles = [
  {
    num: "01",
    title: "ツールから考えない。",
    en: "Work first, tools second.",
    body: "まず、仕事の流れを観察する。その上で、必要なデジタルだけを入れる。",
  },
  {
    num: "02",
    title: "小さく作り、早く試す。",
    en: "Small build, fast proof.",
    body: "大きな構想で止めない。小さく作り、数字を見ながら改善する。",
  },
  {
    num: "03",
    title: "仕組みを、会社に残す。",
    en: "Leave the system behind.",
    body: "外部の支援がなくても回る状態を目指す。ルール、権限、入力、確認、改善のリズムまで設計する。",
  },
];

const overview = [
  { key: "屋号", value: SITE.brandJa },
  { key: "代表", value: SITE.representative },
  {
    key: "事業内容",
    value:
      "業務設計、営業・顧客管理改善、バックオフィス改善、AI活用支援、データ可視化、運用定着支援",
  },
  { key: "対応形式", value: "オンライン / 必要に応じて対面相談" },
  { key: "対応企業", value: "地域企業、中小企業、成長企業" },
  { key: "活動開始", value: "2026年" },
  { key: "お問い合わせ", value: "フォームより受付" },
];

// 1層目:経験領域をMECEに整理
const experienceDomains = [
  {
    num: "01",
    en: "Sales / Revenue Design",
    ja: "営業・顧客接点の設計",
    body: [
      "インサイドセールス、フィールドセールス、アカウントエグゼクティブとして、法人顧客への提案活動に従事。",
      "顧客課題の整理、営業プロセスの設計、CRM/SFA活用、マーケティング施策との連携を通じて、売上につながる顧客接点づくりを経験。",
    ],
  },
  {
    num: "02",
    en: "Product / Service Design",
    ja: "プロダクト・サービスの設計",
    body: [
      "HR TechサービスやSaaS型ERPサービスにおいて、プロダクト開発、プロダクト企画、機能改善提案に従事。",
      "営業現場や顧客の声をもとに、サービスの使いやすさ、提供価値、競争力を高めるための改善に取り組む。",
    ],
  },
  {
    num: "03",
    en: "Customer Experience / Operations",
    ja: "顧客体験・運用体制の設計",
    body: [
      "カスタマーエクスペリエンス領域において、顧客対応、サポート体制、利用定着に関わる仕組みづくりを担当。",
      "導入して終わりではなく、顧客が使い続けられる状態をつくるための運用設計に取り組む。",
    ],
  },
  {
    num: "04",
    en: "Business Growth / Leadership",
    ja: "事業成長・サービス責任",
    body: [
      "ジョブカン経費精算/ワークフローのサービス責任者として、プロダクト、営業、顧客体験を横断しながら事業成長を推進。",
      "市場ニーズを捉えた改善、販売戦略の強化、プロダクトの競争力向上を通じて、サービスの成長に携わる。",
    ],
  },
];

// 2層目:実際のキャリアの時系列
const careerTimeline = [
  {
    tag: "HR Tech",
    body: [
      "大手人材会社の経営企画本部に所属。HR Techサービスにおいて、インサイドセールス、フィールドセールス、プロダクト開発に従事。",
      "営業現場とプロダクトの両面から、顧客課題とサービス改善に向き合う。",
    ],
  },
  {
    tag: "SaaS ERP",
    body: [
      "クラウドサービス事業を展開する企業にて、SaaS型ERPサービスのインサイドセールス、営業企画、プロダクト企画、カスタマーエクスペリエンスを担当。",
      "SalesforceやMarketoを活用したマーケティング戦略の立案・実行、営業プロセス設計、機能改善提案、新規ビジネス開発、サポート体制の構築に取り組む。",
    ],
  },
  {
    tag: "Service Leadership",
    body: [
      "ジョブカン経費精算/ワークフローのサービス責任者として、プロダクト、営業、顧客体験を横断して事業成長を推進。",
      "市場ニーズを捉えた改善と販売戦略の強化を通じて、プロダクトの競争力向上と市場拡大に貢献。",
    ],
  },
  {
    tag: "CRM / DX Support",
    body: [
      "現在はSalesforceにてアカウントエグゼクティブとして勤務。",
      "法人営業の最前線で、企業のCRM活用、営業改革、業務改善、DX推進を支援している。",
    ],
  },
  {
    tag: "ミチカク",
    body: [
      "これまでの営業、プロダクト、顧客体験、事業運営の経験をもとに、企業の仕事の流れを整理し、現場に根づくデジタル活用を支援する。",
    ],
  },
];
---

<Base
  title="ミチカクについて | ミチカク"
  description="ミチカクの事業概要。私たちの考え方、代表プロフィール、経歴、事業内容、対応形式をご紹介します。"
>
  <Header />
  <main>
    <PageIntro
      label="About"
      titleEn="About"
      titleJa="ミチカクについて"
      lead="私たちは、業務とデータの流れを整え、事業が動く仕組みをつくります。"
    />

    <!-- Mission -->
    <section class="section mission">
      <div class="container">
        <p class="en-label reveal">Mission</p>
        <p class="mission__statement reveal" style="--reveal-delay: 0.15s">
          事業が動く仕組みを、設計する。
        </p>
        <p class="mission__body reveal" style="--reveal-delay: 0.25s">
          私たちは、ツールを売る会社ではありません。
          営業、管理部門、経営判断——会社の中で分断されがちな仕事とデータの流れを整え、
          デジタルが現場で自然に使われる状態をつくることを仕事にしています。
        </p>
      </div>
    </section>

    <!-- 考え方 -->
    <section class="section principles">
      <div class="container">
        <p class="en-label principles__label reveal">Principles</p>
        <h2 class="heading-ja principles__heading reveal" style="--reveal-delay: 0.1s">
          私たちの考え方
        </h2>

        <ol class="principles__list">
          {
            principles.map((principle) => (
              <li class="principles__row reveal">
                <span class="principles__num">{principle.num}</span>
                <div>
                  <h3 class="principles__title">{principle.title}</h3>
                  <span class="principles__en">{principle.en}</span>
                </div>
                <p class="principles__body">{principle.body}</p>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <!-- 代表プロフィール -->
    <section class="section profile">
      <div class="container">
        <p class="en-label reveal">Profile</p>
        <h2 class="heading-ja profile__heading reveal" style="--reveal-delay: 0.1s">
          代表プロフィール
        </h2>

        <div class="profile__inner reveal" style="--reveal-delay: 0.2s">
          <div class="profile__name-block">
            <span class="profile__role">代表</span>
            <span class="profile__name">{SITE.representative}</span>
            <span class="profile__name-en">Genki Mouri</span>
          </div>
          <div class="profile__body">
            <p>
              外資系IT企業で法人営業として、CRM/SFAをはじめとする業務システムの導入・活用支援に携わる。
              導入したものの現場で使われないシステム、数字が集まらないままの経営会議——
              その原因の多くがツールではなく仕事の流れの設計にあることを、現場で繰り返し見てきました。
            </p>
            <p>
              この経験をもとに、業務とデータの流れを整えることから始める実装型の支援を行うため、
              「ミチカク」を立ち上げ。地域で事業を続ける会社が、無理のない形でデジタルを使い、
              事業を前に進めていけるよう支援しています。
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Career -->
    <section class="section career">
      <div class="container">
        <p class="en-label reveal">Career</p>
        <h2 class="career__title en-display reveal" style="--reveal-delay: 0.1s">
          Career
        </h2>
        <p class="career__sub reveal" style="--reveal-delay: 0.2s">
          営業、プロダクト、顧客体験、事業運営を横断してきました。
        </p>

        <div class="career__lead reveal" style="--reveal-delay: 0.3s">
          <p>
            毛利元樹は、HR Tech、SaaS ERP、CRM領域において、営業現場、営業企画、プロダクト企画、カスタマーエクスペリエンス、事業責任を経験してきました。
          </p>
          <p class="career__lead-questions">
            顧客接点をどう設計するか。<br />
            プロダクトをどう改善するか。<br />
            顧客体験をどう整えるか。<br />
            事業をどう伸ばすか。
          </p>
          <p>
            それぞれの立場から、仕事が前に進むための仕組みづくりに向き合ってきました。
          </p>
        </div>

        <!-- 1層目:経験領域 -->
        <div class="career__layer">
          <p class="career__layer-label reveal">Experience Domains — 経験領域</p>
          <ol class="career__domains">
            {
              experienceDomains.map((domain, i) => (
                <li class="career__domain reveal" style={`--reveal-delay: ${i * 0.08}s`}>
                  <span class="career__domain-num">{domain.num}</span>
                  <div class="career__domain-text">
                    <h3 class="career__domain-en en-display">{domain.en}</h3>
                    <p class="career__domain-ja">{domain.ja}</p>
                    <div class="career__domain-body">
                      {domain.body.map((line) => (
                        <p>{line}</p>
                      ))}
                    </div>
                  </div>
                </li>
              ))
            }
          </ol>
        </div>

        <!-- 2層目:時系列 -->
        <div class="career__layer">
          <p class="career__layer-label reveal">Career Timeline — 経歴</p>
          <ol class="career__timeline">
            {
              careerTimeline.map((item, i) => (
                <li class="career__entry reveal" style={`--reveal-delay: ${i * 0.08}s`}>
                  <span class="career__marker" aria-hidden="true" />
                  <span class="career__tag">{item.tag}</span>
                  <div class="career__body">
                    {item.body.map((line) => (
                      <p>{line}</p>
                    ))}
                  </div>
                </li>
              ))
            }
          </ol>
        </div>

        <p class="career__closing reveal">
          これまで一貫して向き合ってきたのは、ツールそのものではなく、現場で仕事が前に進むための仕組みづくりです。
          ミチカクでは、営業、管理部門、経営判断の流れを整理し、企業ごとに合ったデジタル活用を設計します。
        </p>
      </div>
    </section>

    <!-- 事業概要テーブル -->
    <section class="section overview">
      <div class="container">
        <p class="en-label overview__label reveal">Overview</p>
        <h2 class="heading-ja overview__heading reveal" style="--reveal-delay: 0.1s">
          事業概要
        </h2>

        <dl class="overview__table reveal" style="--reveal-delay: 0.2s">
          {
            overview.map((row) => (
              <div class="overview__row">
                <dt>{row.key}</dt>
                <dd>{row.value}</dd>
              </div>
            ))
          }
        </dl>

        <div class="overview__cta reveal">
          <a href={`${base}#contact`} class="overview__btn cta-flow"
            >相談する<span class="cta-arrow" aria-hidden="true">→</span></a
          >
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Base>

<style>
  /* --- Mission --- */
  .mission {
    background: var(--c-black);
    border-top: 1px solid var(--line);
  }

  .mission__statement {
    margin-top: 48px;
    font-size: clamp(26px, 4vw, 44px);
    font-weight: 400;
    letter-spacing: 0.12em;
    line-height: 1.8;
  }

  .mission__body {
    margin-top: 40px;
    max-width: 640px;
    font-size: 14.5px;
    line-height: 2.4;
    color: var(--c-muted);
  }

  /* --- 考え方(オフホワイト反転) --- */
  .principles {
    background: var(--c-paper);
    color: var(--c-ink-dark);
  }

  .principles__label {
    color: var(--c-blue);
  }

  .principles__label::before {
    background: var(--c-blue);
  }

  .principles__heading {
    margin-top: 36px;
  }

  .principles__list {
    margin-top: 88px;
    list-style: none;
  }

  .principles__row {
    display: grid;
    grid-template-columns: 90px 1.1fr 1fr;
    gap: clamp(20px, 3vw, 56px);
    align-items: baseline;
    padding-block: clamp(44px, 6vw, 72px);
    border-top: 1px solid var(--line-dark);
  }

  .principles__row:last-child {
    border-bottom: 1px solid var(--line-dark);
  }

  .principles__num {
    font-family: var(--font-en);
    font-weight: 200;
    font-size: 13px;
    letter-spacing: 0.2em;
    color: var(--c-blue);
  }

  .principles__title {
    font-size: clamp(20px, 2.6vw, 28px);
    font-weight: 400;
    letter-spacing: 0.1em;
  }

  .principles__en {
    display: block;
    margin-top: 12px;
    font-family: var(--font-en);
    font-weight: 300;
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--c-muted-dark);
  }

  .principles__body {
    font-size: 14.5px;
    line-height: 2.3;
    color: var(--c-muted-dark);
  }

  /* --- 代表プロフィール --- */
  .profile {
    background: var(--c-charcoal);
    border-block: 1px solid var(--line);
  }

  .profile__heading {
    margin-top: 36px;
  }

  .profile__inner {
    margin-top: 88px;
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: clamp(40px, 6vw, 112px);
    align-items: start;
  }

  .profile__name-block {
    display: flex;
    flex-direction: column;
    gap: 10px;
    border-top: 1px solid var(--c-gold-dim);
    padding-top: 28px;
  }

  .profile__role {
    font-size: 12px;
    letter-spacing: 0.2em;
    color: var(--c-muted);
  }

  .profile__name {
    font-size: clamp(24px, 3vw, 32px);
    font-weight: 500;
    letter-spacing: 0.16em;
  }

  .profile__name-en {
    font-family: var(--font-en);
    font-weight: 300;
    font-size: 13px;
    letter-spacing: 0.12em;
    color: var(--c-muted);
  }

  .profile__body p {
    font-size: 14.5px;
    line-height: 2.4;
    color: var(--c-muted);
  }

  .profile__body p + p {
    margin-top: 1.8em;
  }

  /* --- Career --- */
  .career {
    background: var(--c-base);
    border-block: 1px solid var(--line);
  }

  .career__title {
    margin-top: 36px;
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 200;
  }

  .career__sub {
    margin-top: 20px;
    font-size: 14px;
    letter-spacing: 0.12em;
    color: var(--c-sub);
  }

  /* リード文 */
  .career__lead {
    margin-top: 44px;
    max-width: 680px;
  }

  .career__lead p {
    font-size: 14.5px;
    line-height: 2.4;
    color: var(--c-text);
  }

  .career__lead p + p {
    margin-top: 1.6em;
  }

  .career__lead-questions {
    color: var(--c-sub) !important;
    letter-spacing: 0.06em;
  }

  /* 2つの層の見出し */
  .career__layer {
    margin-top: clamp(72px, 9vw, 112px);
  }

  .career__layer-label {
    font-size: 12px;
    letter-spacing: 0.2em;
    color: var(--c-blue);
    padding-bottom: 20px;
    border-bottom: 1px solid var(--c-hairline);
  }

  /* --- 1層目:経験領域 --- */
  .career__domains {
    margin-top: 8px;
    list-style: none;
  }

  .career__domain {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: clamp(16px, 3vw, 40px);
    padding-block: clamp(36px, 4.5vw, 52px);
    border-bottom: 1px solid var(--c-hairline);
  }

  .career__domain-num {
    font-family: var(--font-en);
    font-weight: 300;
    font-size: 14px;
    letter-spacing: 0.14em;
    color: var(--c-blue);
    padding-top: 6px;
  }

  .career__domain-en {
    font-size: clamp(22px, 2.6vw, 32px);
    font-weight: 300;
  }

  .career__domain-ja {
    margin-top: 10px;
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 0.1em;
  }

  .career__domain-body {
    margin-top: 20px;
    max-width: 620px;
  }

  .career__domain-body p {
    font-size: 13.5px;
    line-height: 2.3;
    color: var(--c-sub);
  }

  .career__domain-body p + p {
    margin-top: 1em;
  }

  /* --- 2層目:時系列 --- */
  .career__timeline {
    margin-top: 56px;
    list-style: none;
    position: relative;
    max-width: 800px;
  }

  .career__timeline::before {
    content: "";
    position: absolute;
    left: 3px;
    top: 8px;
    bottom: 8px;
    width: 1px;
    background: var(--c-hairline);
  }

  .career__entry {
    position: relative;
    padding: 0 0 clamp(48px, 6vw, 72px) clamp(40px, 5vw, 64px);
  }

  .career__entry:last-child {
    padding-bottom: 0;
  }

  .career__marker {
    position: absolute;
    left: 0;
    top: 8px;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    border: 1px solid var(--c-blue);
    background: var(--c-base);
  }

  .career__entry:last-child .career__marker {
    background: var(--c-blue);
  }

  .career__tag {
    display: block;
    font-family: var(--font-en);
    font-weight: 400;
    font-size: 17px;
    letter-spacing: 0.14em;
  }

  .career__body {
    margin-top: 14px;
    max-width: 660px;
  }

  .career__body p {
    font-size: 13.5px;
    line-height: 2.3;
    color: var(--c-sub);
  }

  .career__body p + p {
    margin-top: 0.6em;
  }

  /* 締めの一文 */
  .career__closing {
    margin-top: clamp(64px, 8vw, 96px);
    max-width: 720px;
    font-size: 14.5px;
    line-height: 2.4;
    letter-spacing: 0.04em;
    color: var(--c-text);
    padding-top: clamp(40px, 5vw, 56px);
    border-top: 1px solid var(--c-hairline);
  }

  @media (max-width: 720px) {
    .career__domain {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }

  /* --- 事業概要テーブル --- */
  .overview {
    background: var(--c-white);
  }

  .overview__heading {
    margin-top: 36px;
  }

  .overview__table {
    margin-top: 88px;
    max-width: 840px;
  }

  .overview__row {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: clamp(20px, 3vw, 48px);
    padding-block: 26px;
    border-top: 1px solid var(--line);
  }

  .overview__row:last-child {
    border-bottom: 1px solid var(--line);
  }

  .overview__row dt {
    font-size: 13px;
    letter-spacing: 0.14em;
    color: var(--c-muted);
  }

  .overview__row dd {
    font-size: 14.5px;
    line-height: 2.1;
    letter-spacing: 0.06em;
  }

  .overview__cta {
    margin-top: 88px;
  }

  .overview__btn {
    display: inline-block;
    padding: 16px 56px;
    border: 1px solid var(--c-gold-dim);
    color: var(--c-gold);
    font-size: 14px;
    letter-spacing: 0.14em;
    transition: background-color 0.35s ease, color 0.35s ease;
  }

  .overview__btn:hover {
    background: var(--c-gold);
    color: var(--c-black);
  }

  @media (max-width: 840px) {
    .principles__row,
    .profile__inner,
    .overview__row {
      grid-template-columns: 1fr;
    }

    .principles__row {
      gap: 16px;
    }

    .overview__row {
      gap: 8px;
      padding-block: 20px;
    }
  }
</style>
