---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import PageIntro from "../components/PageIntro.astro";
import Footer from "../components/Footer.astro";
import { SITE } from "../config";
import { CAREER } from "../data/career";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const principles = [
  {
    num: "01",
    title: "ツールから考えない。",
    en: "Work first, tools second.",
    body: "まず、仕事の流れを観察する。その上で、必要なデジタルだけを入れる。",
  },
  {
    num: "02",
    title: "小さく作り、早く試す。",
    en: "Small build, fast proof.",
    body: "大きな構想で止めない。小さく作り、数字を見ながら改善する。",
  },
  {
    num: "03",
    title: "仕組みを、会社に残す。",
    en: "Leave the system behind.",
    body: "外部の支援がなくても回る状態を目指す。ルール、権限、入力、確認、改善のリズムまで設計する。",
  },
];

const overview = [
  { key: "屋号", value: SITE.brandJa },
  { key: "代表", value: SITE.representative },
  {
    key: "事業内容",
    value:
      "業務設計、営業・顧客管理改善、バックオフィス改善、AI活用支援、データ可視化、運用定着支援",
  },
  { key: "対応形式", value: "オンライン / 必要に応じて対面相談" },
  { key: "対応企業", value: "地域企業、中小企業、成長企業" },
  { key: "活動開始", value: "2026年" },
  { key: "お問い合わせ", value: "フォームより受付" },
];

---

<Base
  title="ミチカクについて | ミチカク"
  description="ミチカクの事業概要。私たちの考え方、代表プロフィール、経歴、事業内容、対応形式をご紹介します。"
>
  <Header />
  <main>
    <PageIntro
      label="About"
      titleEn="About"
      titleJa="ミチカクについて"
      lead="私たちは、業務とデータの流れを整え、事業が動く仕組みをつくります。"
    />

    <!-- Mission -->
    <section class="section mission">
      <div class="container">
        <p class="en-label reveal">Mission</p>
        <p class="mission__statement reveal" style="--reveal-delay: 0.15s">
          事業が動く仕組みを、設計する。
        </p>
        <p class="mission__body reveal" style="--reveal-delay: 0.25s">
          私たちは、ツールを売る会社ではありません。
          営業、管理部門、経営判断——会社の中で分断されがちな仕事とデータの流れを整え、
          デジタルが現場で自然に使われる状態をつくることを仕事にしています。
        </p>
      </div>
    </section>

    <!-- 考え方 -->
    <section class="section principles">
      <div class="container">
        <p class="en-label principles__label reveal">Principles</p>
        <h2 class="heading-ja principles__heading reveal" style="--reveal-delay: 0.1s">
          私たちの考え方
        </h2>

        <ol class="principles__list">
          {
            principles.map((principle) => (
              <li class="principles__row reveal">
                <span class="principles__num">{principle.num}</span>
                <div>
                  <h3 class="principles__title">{principle.title}</h3>
                  <span class="principles__en">{principle.en}</span>
                </div>
                <p class="principles__body">{principle.body}</p>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <!-- 代表プロフィール -->
    <section class="section profile">
      <div class="container">
        <p class="en-label reveal">Profile</p>
        <h2 class="heading-ja profile__heading reveal" style="--reveal-delay: 0.1s">
          代表プロフィール
        </h2>

        <div class="profile__inner reveal" style="--reveal-delay: 0.2s">
          <div class="profile__name-block">
            <span class="profile__role">代表</span>
            <span class="profile__name">{SITE.representative}</span>
            <span class="profile__name-en">Genki Mouri</span>
          </div>
          <div class="profile__body">
            <p>
              外資系IT企業で法人営業として、CRM/SFAをはじめとする業務システムの導入・活用支援に携わる。
              導入したものの現場で使われないシステム、数字が集まらないままの経営会議——
              その原因の多くがツールではなく仕事の流れの設計にあることを、現場で繰り返し見てきました。
            </p>
            <p>
              この経験をもとに、業務とデータの流れを整えることから始める実装型の支援を行うため、
              「ミチカク」を立ち上げ。地域で事業を続ける会社が、無理のない形でデジタルを使い、
              事業を前に進めていけるよう支援しています。
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Career:一続きのEditorial Narrative -->
    <section class="section career" id="career">
      <div class="container">
        <p class="en-label reveal">Career</p>
        <h2 class="career__title en-display reveal" style="--reveal-delay: 0.1s">
          Career
        </h2>
        <p class="career__copy reveal" style="--reveal-delay: 0.2s">
          つくる。届ける。使われ続ける。
        </p>
        <p class="career__lead reveal" style="--reveal-delay: 0.3s">
          {CAREER.lead}
        </p>

        <!-- 3つのキャリア段階を、一本のオレンジの道筋がつなぐ -->
        <div class="career__narrative reveal">
          <span class="career__thread" aria-hidden="true"></span>

          {
            CAREER.stages.map((stage, i) => (
              <div class="career__stage">
                <p
                  class="career__stage-label reveal"
                  style={`--reveal-delay: ${0.15 + i * 0.1}s`}
                >
                  {stage.label}
                </p>
                {stage.body.map((paragraph, j) => (
                  <p
                    class="career__paragraph reveal"
                    style={`--reveal-delay: ${0.35 + i * 0.1 + j * 0.12}s`}
                  >
                    {paragraph}
                  </p>
                ))}
              </div>
            ))
          }

          <div class="career__stage career__stage--closing">
            {
              CAREER.closing.map((paragraph, i) => (
                <p
                  class="career__paragraph reveal"
                  style={`--reveal-delay: ${0.3 + i * 0.12}s`}
                >
                  {paragraph}
                </p>
              ))
            }
          </div>

          <!-- 道筋の終端:タグラインへ -->
          <p class="career__tail reveal" style="--reveal-delay: 0.3s">
            仕事に、道筋を。
          </p>
        </div>

        <p class="career__note reveal">{CAREER.disclaimer}</p>
      </div>
    </section>

    <!-- 事業概要テーブル -->
    <section class="section overview">
      <div class="container">
        <p class="en-label overview__label reveal">Overview</p>
        <h2 class="heading-ja overview__heading reveal" style="--reveal-delay: 0.1s">
          事業概要
        </h2>

        <dl class="overview__table reveal" style="--reveal-delay: 0.2s">
          {
            overview.map((row) => (
              <div class="overview__row">
                <dt>{row.key}</dt>
                <dd>{row.value}</dd>
              </div>
            ))
          }
        </dl>

        <div class="overview__cta reveal">
          <a href={`${base}#contact`} class="overview__btn cta-flow"
            >相談する<span class="cta-arrow" aria-hidden="true">→</span></a
          >
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Base>

<style>
  /* --- Mission --- */
  .mission {
    background: var(--c-black);
    border-top: 1px solid var(--line);
  }

  .mission__statement {
    margin-top: 48px;
    font-size: clamp(26px, 4vw, 44px);
    font-weight: 400;
    letter-spacing: 0.12em;
    line-height: 1.8;
  }

  .mission__body {
    margin-top: 40px;
    max-width: 640px;
    font-size: 14.5px;
    line-height: 2.4;
    color: var(--c-muted);
  }

  /* --- 考え方(オフホワイト反転) --- */
  .principles {
    background: var(--c-paper);
    color: var(--c-ink-dark);
  }

  .principles__label {
    color: var(--c-blue);
  }

  .principles__label::before {
    background: var(--c-blue);
  }

  .principles__heading {
    margin-top: 36px;
  }

  .principles__list {
    margin-top: 88px;
    list-style: none;
  }

  .principles__row {
    display: grid;
    grid-template-columns: 90px 1.1fr 1fr;
    gap: clamp(20px, 3vw, 56px);
    align-items: baseline;
    padding-block: clamp(44px, 6vw, 72px);
    border-top: 1px solid var(--line-dark);
  }

  .principles__row:last-child {
    border-bottom: 1px solid var(--line-dark);
  }

  .principles__num {
    font-family: var(--font-en);
    font-weight: 200;
    font-size: 13px;
    letter-spacing: 0.2em;
    color: var(--c-blue);
  }

  .principles__title {
    font-size: clamp(20px, 2.6vw, 28px);
    font-weight: 400;
    letter-spacing: 0.1em;
  }

  .principles__en {
    display: block;
    margin-top: 12px;
    font-family: var(--font-en);
    font-weight: 300;
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--c-muted-dark);
  }

  .principles__body {
    font-size: 14.5px;
    line-height: 2.3;
    color: var(--c-muted-dark);
  }

  /* --- 代表プロフィール --- */
  .profile {
    background: var(--c-charcoal);
    border-block: 1px solid var(--line);
  }

  .profile__heading {
    margin-top: 36px;
  }

  .profile__inner {
    margin-top: 88px;
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: clamp(40px, 6vw, 112px);
    align-items: start;
  }

  .profile__name-block {
    display: flex;
    flex-direction: column;
    gap: 10px;
    border-top: 1px solid var(--c-gold-dim);
    padding-top: 28px;
  }

  .profile__role {
    font-size: 12px;
    letter-spacing: 0.2em;
    color: var(--c-muted);
  }

  .profile__name {
    font-size: clamp(24px, 3vw, 32px);
    font-weight: 500;
    letter-spacing: 0.16em;
  }

  .profile__name-en {
    font-family: var(--font-en);
    font-weight: 300;
    font-size: 13px;
    letter-spacing: 0.12em;
    color: var(--c-muted);
  }

  .profile__body p {
    font-size: 14.5px;
    line-height: 2.4;
    color: var(--c-muted);
  }

  .profile__body p + p {
    margin-top: 1.8em;
  }

  /* --- Career:Editorial Narrative --- */
  .career {
    background: var(--c-base);
    border-block: 1px solid var(--line);
  }

  .career__title {
    margin-top: 36px;
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 200;
  }

  .career__copy {
    margin-top: 28px;
    font-size: clamp(18px, 2.2vw, 24px);
    font-weight: 500;
    letter-spacing: 0.14em;
  }

  .career__lead {
    margin-top: 32px;
    max-width: 620px;
    font-size: 14.5px;
    line-height: 2.4;
    color: var(--c-sub);
  }

  /* --- 一本のオレンジの道筋がつなぐ物語 --- */
  .career__narrative {
    position: relative;
    margin-top: 88px;
    max-width: 720px;
    padding-left: clamp(28px, 4vw, 52px);
  }

  .career__thread {
    position: absolute;
    left: 3px;
    top: 6px;
    bottom: 6px;
    width: 1.5px;
    background: rgba(255, 90, 31, 0.55);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 1.6s cubic-bezier(0.22, 1, 0.36, 1) 0.1s;
  }

  .career__narrative.is-visible .career__thread {
    transform: scaleY(1);
  }

  .career__stage + .career__stage {
    margin-top: clamp(52px, 6vw, 72px);
  }

  .career__stage-label {
    font-family: var(--font-en);
    font-weight: 400;
    font-size: 12px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--c-primary);
  }

  .career__paragraph {
    margin-top: 20px;
    font-size: 14.5px;
    line-height: 2.5;
    color: var(--c-text);
    letter-spacing: 0.04em;
  }

  .career__paragraph + .career__paragraph {
    margin-top: 1.6em;
  }

  /* 締め(強み・関心):段階と少し距離を取る */
  .career__stage--closing {
    margin-top: clamp(64px, 8vw, 88px);
    padding-top: clamp(36px, 4vw, 48px);
    border-top: 1px solid var(--c-hairline);
  }

  .career__stage--closing .career__paragraph {
    color: var(--c-sub);
    font-size: 14px;
  }

  /* 道筋の終端:タグラインに到達する */
  .career__tail {
    position: relative;
    margin-top: clamp(56px, 7vw, 72px);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.22em;
    color: var(--c-text);
  }

  .career__tail::before {
    content: "";
    position: absolute;
    left: calc(-1 * clamp(28px, 4vw, 52px) + 3px);
    top: 50%;
    width: calc(clamp(28px, 4vw, 52px) - 17px);
    height: 1.5px;
    background: rgba(255, 90, 31, 0.55);
  }

  .career__tail::after {
    content: "";
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--c-secondary);
    margin-left: 14px;
    vertical-align: middle;
  }

  /* 所属企業に関する注記 */
  .career__note {
    margin-top: clamp(64px, 8vw, 88px);
    max-width: 720px;
    font-size: 10.5px;
    line-height: 2;
    letter-spacing: 0.06em;
    color: var(--c-sub);
    opacity: 0.75;
  }

  @media (prefers-reduced-motion: reduce) {
    .career__thread {
      transition: none;
      transform: none;
    }
  }

  /* --- 事業概要テーブル --- */
  .overview {
    background: var(--c-white);
  }

  .overview__heading {
    margin-top: 36px;
  }

  .overview__table {
    margin-top: 88px;
    max-width: 840px;
  }

  .overview__row {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: clamp(20px, 3vw, 48px);
    padding-block: 26px;
    border-top: 1px solid var(--line);
  }

  .overview__row:last-child {
    border-bottom: 1px solid var(--line);
  }

  .overview__row dt {
    font-size: 13px;
    letter-spacing: 0.14em;
    color: var(--c-muted);
  }

  .overview__row dd {
    font-size: 14.5px;
    line-height: 2.1;
    letter-spacing: 0.06em;
  }

  .overview__cta {
    margin-top: 88px;
  }

  /* Primary CTA:焼きオレンジ */
  .overview__btn {
    display: inline-block;
    padding: 16px 56px;
    background: var(--c-primary);
    border: 1px solid var(--c-primary);
    border-radius: 10px;
    color: #fff;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.14em;
    transition: background-color 0.35s ease, border-color 0.35s ease,
      translate 0.35s ease;
  }

  .overview__btn:hover {
    background: var(--c-primary-dark);
    border-color: var(--c-primary-dark);
    translate: 0 -2px;
  }

  @media (max-width: 840px) {
    .principles__row,
    .profile__inner,
    .overview__row {
      grid-template-columns: 1fr;
    }

    .principles__row {
      gap: 16px;
    }

    .overview__row {
      gap: 8px;
      padding-block: 20px;
    }
  }
</style>
