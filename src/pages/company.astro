---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import PageIntro from "../components/PageIntro.astro";
import Footer from "../components/Footer.astro";
import { SITE } from "../config";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const principles = [
  {
    num: "01",
    title: "ツールから考えない。",
    en: "Work first, tools second.",
    body: "まず、仕事の流れを観察する。その上で、必要なデジタルだけを入れる。",
  },
  {
    num: "02",
    title: "小さく作り、早く試す。",
    en: "Small build, fast proof.",
    body: "大きな構想で止めない。小さく作り、数字を見ながら改善する。",
  },
  {
    num: "03",
    title: "仕組みを、会社に残す。",
    en: "Leave the system behind.",
    body: "外部の支援がなくても回る状態を目指す。ルール、権限、入力、確認、改善のリズムまで設計する。",
  },
];

const overview = [
  { key: "屋号", value: SITE.brandJa },
  { key: "代表", value: SITE.representative },
  {
    key: "事業内容",
    value:
      "業務設計、営業・顧客管理改善、バックオフィス改善、AI活用支援、データ可視化、運用定着支援",
  },
  { key: "対応形式", value: "オンライン / 必要に応じて対面相談" },
  { key: "対応企業", value: "地域企業、中小企業、成長企業" },
  { key: "活動開始", value: "2026年" },
  { key: "お問い合わせ", value: "フォームより受付" },
];

const career = [
  {
    tag: "HR Tech",
    roles: ["インサイドセールス", "フィールドセールス", "プロダクト開発"],
    body: "大手人材会社の経営企画本部にて、HR Techサービスのインサイドセールス、フィールドセールス、プロダクト開発に従事。営業現場とプロダクトの両面から事業成長に携わる。",
  },
  {
    tag: "SaaS ERP",
    roles: ["営業企画", "プロダクト企画", "CX", "Salesforce", "Marketo"],
    body: "クラウドサービス企業にて、SaaS型ERPサービスの営業企画、プロダクト企画、カスタマーエクスペリエンスを担当。SalesforceやMarketoを活用したマーケティング・営業プロセスの設計、機能改善、新規ビジネス開発、サポート体制の構築を推進。",
  },
  {
    tag: "Service Leadership",
    roles: ["サービス責任者", "プロダクト", "営業", "顧客体験"],
    body: "ジョブカン経費精算/ワークフローのサービス責任者として、プロダクト、営業、顧客体験を横断して事業成長をリード。プロダクトの競争力強化と市場拡大に取り組む。",
  },
  {
    tag: "CRM / DX Support",
    roles: ["CRM活用", "営業改革", "業務改善", "DX推進"],
    body: "現在は外資系CRM企業にて、法人企業のCRM活用、営業改革、業務改善、DX推進を支援。",
  },
  {
    tag: "ミチカク",
    roles: ["営業", "マーケティング", "プロダクト", "CX", "事業責任"],
    body: "営業、マーケティング、プロダクト、CX、事業責任の経験を活かし、ツール導入で終わらない、現場に根づくデジタル活用を支援する。",
  },
];
---

<Base
  title="ミチカクについて | ミチカク"
  description="ミチカクの事業概要。私たちの考え方、代表プロフィール、経歴、事業内容、対応形式をご紹介します。"
>
  <Header />
  <main>
    <PageIntro
      label="About"
      titleEn="About"
      titleJa="ミチカクについて"
      lead="私たちは、業務とデータの流れを整え、事業が動く仕組みをつくります。"
    />

    <!-- Mission -->
    <section class="section mission">
      <div class="container">
        <p class="en-label reveal">Mission</p>
        <p class="mission__statement reveal" style="--reveal-delay: 0.15s">
          事業が動く仕組みを、設計する。
        </p>
        <p class="mission__body reveal" style="--reveal-delay: 0.25s">
          私たちは、ツールを売る会社ではありません。
          営業、管理部門、経営判断——会社の中で分断されがちな仕事とデータの流れを整え、
          デジタルが現場で自然に使われる状態をつくることを仕事にしています。
        </p>
      </div>
    </section>

    <!-- 考え方 -->
    <section class="section principles">
      <div class="container">
        <p class="en-label principles__label reveal">Principles</p>
        <h2 class="heading-ja principles__heading reveal" style="--reveal-delay: 0.1s">
          私たちの考え方
        </h2>

        <ol class="principles__list">
          {
            principles.map((principle) => (
              <li class="principles__row reveal">
                <span class="principles__num">{principle.num}</span>
                <div>
                  <h3 class="principles__title">{principle.title}</h3>
                  <span class="principles__en">{principle.en}</span>
                </div>
                <p class="principles__body">{principle.body}</p>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <!-- 代表プロフィール -->
    <section class="section profile">
      <div class="container">
        <p class="en-label reveal">Profile</p>
        <h2 class="heading-ja profile__heading reveal" style="--reveal-delay: 0.1s">
          代表プロフィール
        </h2>

        <div class="profile__inner reveal" style="--reveal-delay: 0.2s">
          <div class="profile__name-block">
            <span class="profile__role">代表</span>
            <span class="profile__name">{SITE.representative}</span>
            <span class="profile__name-en">Genki Mouri</span>
          </div>
          <div class="profile__body">
            <p>
              外資系IT企業で法人営業として、CRM/SFAをはじめとする業務システムの導入・活用支援に携わる。
              導入したものの現場で使われないシステム、数字が集まらないままの経営会議——
              その原因の多くがツールではなく仕事の流れの設計にあることを、現場で繰り返し見てきました。
            </p>
            <p>
              この経験をもとに、業務とデータの流れを整えることから始める実装型の支援を行うため、
              「ミチカク」を立ち上げ。地域で事業を続ける会社が、無理のない形でデジタルを使い、
              事業を前に進めていけるよう支援しています。
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Career -->
    <section class="section career">
      <div class="container">
        <p class="en-label reveal">Career</p>
        <h2 class="career__title en-display reveal" style="--reveal-delay: 0.1s">
          Career
        </h2>
        <p class="career__sub reveal" style="--reveal-delay: 0.2s">
          営業、プロダクト、顧客体験、事業成長の接点で。
        </p>

        <ol class="career__timeline">
          {
            career.map((item, i) => (
              <li class="career__entry reveal" style={`--reveal-delay: ${i * 0.08}s`}>
                <span class="career__marker" aria-hidden="true" />
                <div class="career__head">
                  <span class="career__tag">{item.tag}</span>
                  <ul class="career__roles" aria-label="担当領域">
                    {item.roles.map((role) => (
                      <li>{role}</li>
                    ))}
                  </ul>
                </div>
                <p class="career__body">{item.body}</p>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <!-- 事業概要テーブル -->
    <section class="section overview">
      <div class="container">
        <p class="en-label overview__label reveal">Overview</p>
        <h2 class="heading-ja overview__heading reveal" style="--reveal-delay: 0.1s">
          事業概要
        </h2>

        <dl class="overview__table reveal" style="--reveal-delay: 0.2s">
          {
            overview.map((row) => (
              <div class="overview__row">
                <dt>{row.key}</dt>
                <dd>{row.value}</dd>
              </div>
            ))
          }
        </dl>

        <div class="overview__cta reveal">
          <a href={`${base}#contact`} class="overview__btn cta-flow"
            >相談する<span class="cta-arrow" aria-hidden="true">→</span></a
          >
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Base>

<style>
  /* --- Mission --- */
  .mission {
    background: var(--c-black);
    border-top: 1px solid var(--line);
  }

  .mission__statement {
    margin-top: 48px;
    font-size: clamp(26px, 4vw, 44px);
    font-weight: 400;
    letter-spacing: 0.12em;
    line-height: 1.8;
  }

  .mission__body {
    margin-top: 40px;
    max-width: 640px;
    font-size: 14.5px;
    line-height: 2.4;
    color: var(--c-muted);
  }

  /* --- 考え方(オフホワイト反転) --- */
  .principles {
    background: var(--c-paper);
    color: var(--c-ink-dark);
  }

  .principles__label {
    color: var(--c-blue);
  }

  .principles__label::before {
    background: var(--c-blue);
  }

  .principles__heading {
    margin-top: 36px;
  }

  .principles__list {
    margin-top: 88px;
    list-style: none;
  }

  .principles__row {
    display: grid;
    grid-template-columns: 90px 1.1fr 1fr;
    gap: clamp(20px, 3vw, 56px);
    align-items: baseline;
    padding-block: clamp(44px, 6vw, 72px);
    border-top: 1px solid var(--line-dark);
  }

  .principles__row:last-child {
    border-bottom: 1px solid var(--line-dark);
  }

  .principles__num {
    font-family: var(--font-en);
    font-weight: 200;
    font-size: 13px;
    letter-spacing: 0.2em;
    color: var(--c-blue);
  }

  .principles__title {
    font-size: clamp(20px, 2.6vw, 28px);
    font-weight: 400;
    letter-spacing: 0.1em;
  }

  .principles__en {
    display: block;
    margin-top: 12px;
    font-family: var(--font-en);
    font-weight: 300;
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--c-muted-dark);
  }

  .principles__body {
    font-size: 14.5px;
    line-height: 2.3;
    color: var(--c-muted-dark);
  }

  /* --- 代表プロフィール --- */
  .profile {
    background: var(--c-charcoal);
    border-block: 1px solid var(--line);
  }

  .profile__heading {
    margin-top: 36px;
  }

  .profile__inner {
    margin-top: 88px;
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: clamp(40px, 6vw, 112px);
    align-items: start;
  }

  .profile__name-block {
    display: flex;
    flex-direction: column;
    gap: 10px;
    border-top: 1px solid var(--c-gold-dim);
    padding-top: 28px;
  }

  .profile__role {
    font-size: 12px;
    letter-spacing: 0.2em;
    color: var(--c-muted);
  }

  .profile__name {
    font-size: clamp(24px, 3vw, 32px);
    font-weight: 500;
    letter-spacing: 0.16em;
  }

  .profile__name-en {
    font-family: var(--font-en);
    font-weight: 300;
    font-size: 13px;
    letter-spacing: 0.12em;
    color: var(--c-muted);
  }

  .profile__body p {
    font-size: 14.5px;
    line-height: 2.4;
    color: var(--c-muted);
  }

  .profile__body p + p {
    margin-top: 1.8em;
  }

  /* --- Career --- */
  .career {
    background: var(--c-base);
    border-block: 1px solid var(--line);
  }

  .career__title {
    margin-top: 36px;
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 200;
  }

  .career__sub {
    margin-top: 20px;
    font-size: 13.5px;
    letter-spacing: 0.12em;
    color: var(--c-sub);
  }

  .career__timeline {
    margin-top: 72px;
    list-style: none;
    position: relative;
    max-width: 800px;
  }

  .career__timeline::before {
    content: "";
    position: absolute;
    left: 3px;
    top: 8px;
    bottom: 8px;
    width: 1px;
    background: var(--c-hairline);
  }

  .career__entry {
    position: relative;
    padding: 0 0 clamp(48px, 6vw, 72px) clamp(40px, 5vw, 64px);
  }

  .career__entry:last-child {
    padding-bottom: 0;
  }

  .career__marker {
    position: absolute;
    left: 0;
    top: 8px;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    border: 1px solid var(--c-blue);
    background: var(--c-base);
  }

  .career__entry:last-child .career__marker {
    background: var(--c-blue);
  }

  .career__head {
    display: flex;
    align-items: baseline;
    gap: 20px;
    flex-wrap: wrap;
  }

  .career__tag {
    font-family: var(--font-en);
    font-weight: 400;
    font-size: 17px;
    letter-spacing: 0.14em;
  }

  /* 担当領域のチップ */
  .career__roles {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .career__roles li {
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--c-sub);
    background: var(--c-white);
    border: 1px solid var(--c-hairline);
    border-radius: 999px;
    padding: 3px 12px;
  }

  .career__body {
    margin-top: 16px;
    font-size: 13.5px;
    line-height: 2.3;
    color: var(--c-sub);
    max-width: 660px;
  }

  /* --- 事業概要テーブル --- */
  .overview {
    background: var(--c-white);
  }

  .overview__heading {
    margin-top: 36px;
  }

  .overview__table {
    margin-top: 88px;
    max-width: 840px;
  }

  .overview__row {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: clamp(20px, 3vw, 48px);
    padding-block: 26px;
    border-top: 1px solid var(--line);
  }

  .overview__row:last-child {
    border-bottom: 1px solid var(--line);
  }

  .overview__row dt {
    font-size: 13px;
    letter-spacing: 0.14em;
    color: var(--c-muted);
  }

  .overview__row dd {
    font-size: 14.5px;
    line-height: 2.1;
    letter-spacing: 0.06em;
  }

  .overview__cta {
    margin-top: 88px;
  }

  .overview__btn {
    display: inline-block;
    padding: 16px 56px;
    border: 1px solid var(--c-gold-dim);
    color: var(--c-gold);
    font-size: 14px;
    letter-spacing: 0.14em;
    transition: background-color 0.35s ease, color 0.35s ease;
  }

  .overview__btn:hover {
    background: var(--c-gold);
    color: var(--c-black);
  }

  @media (max-width: 840px) {
    .principles__row,
    .profile__inner,
    .overview__row {
      grid-template-columns: 1fr;
    }

    .principles__row {
      gap: 16px;
    }

    .overview__row {
      gap: 8px;
      padding-block: 20px;
    }
  }
</style>
